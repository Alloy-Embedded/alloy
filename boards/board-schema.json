{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/lgili/corezero/schemas/board-config.json",
  "title": "MicroCore Board Configuration",
  "description": "Canonical schema for MicroCore board metadata (board.yaml).",
  "type": "object",
  "required": [
    "schema_version",
    "board",
    "platform",
    "mcu",
    "clock",
    "build",
    "tooling",
    "leds"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^1\\.0$",
      "description": "Board metadata schema version"
    },
    "board": {
      "type": "object",
      "required": ["id", "name", "vendor", "version"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9_]+$",
          "description": "Stable board identifier matching directory name"
        },
        "name": {
          "type": "string",
          "description": "Board display name"
        },
        "vendor": {
          "type": "string",
          "description": "Board manufacturer"
        },
        "version": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+\\.\\d+$",
          "description": "Board metadata version (semver)"
        },
        "description": {
          "type": "string",
          "description": "Human-readable board description"
        },
        "url": {
          "type": "string",
          "format": "uri",
          "description": "URL to board docs/product page"
        }
      }
    },
    "platform": {
      "type": "string",
      "enum": [
        "stm32f0",
        "stm32f1",
        "stm32f4",
        "stm32f7",
        "stm32g0",
        "stm32g4",
        "stm32h7",
        "same70",
        "host"
      ],
      "description": "Canonical MicroCore platform identifier"
    },
    "mcu": {
      "type": "object",
      "required": ["part_number", "architecture"],
      "additionalProperties": false,
      "properties": {
        "part_number": {
          "type": "string",
          "description": "Full MCU part number"
        },
        "generated_namespace": {
          "type": "string",
          "pattern": "^[a-z0-9_]+$",
          "description": "Override namespace/path used for generated MCU artifacts"
        },
        "architecture": {
          "type": "string",
          "enum": [
            "cortex-m0",
            "cortex-m0+",
            "cortex-m3",
            "cortex-m4",
            "cortex-m7",
            "cortex-m33"
          ],
          "description": "ARM Cortex-M architecture"
        },
        "flash_kb": {
          "type": "integer",
          "minimum": 16,
          "description": "Flash memory size in KB"
        },
        "ram_kb": {
          "type": "integer",
          "minimum": 4,
          "description": "RAM size in KB"
        },
        "frequency_mhz": {
          "type": "integer",
          "minimum": 1,
          "description": "Target CPU frequency in MHz"
        }
      }
    },
    "clock": {
      "type": "object",
      "required": ["source", "system_clock_hz"],
      "additionalProperties": false,
      "properties": {
        "source": {
          "type": "string",
          "enum": ["HSI", "HSE", "PLL", "RC"],
          "description": "Primary clock source"
        },
        "system_clock_hz": {
          "type": "integer",
          "minimum": 1000000,
          "description": "System clock in Hz"
        },
        "hse_hz": {
          "type": "integer",
          "minimum": 1000000,
          "description": "External crystal frequency in Hz"
        },
        "pll": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "m": { "type": "integer", "minimum": 1 },
            "n": { "type": "integer", "minimum": 1 },
            "p": { "type": "integer", "minimum": 1 },
            "q": { "type": "integer", "minimum": 1 },
            "r": { "type": "integer", "minimum": 1 }
          }
        },
        "ahb_prescaler": {
          "type": "integer",
          "minimum": 1,
          "description": "AHB prescaler"
        },
        "apb1_prescaler": {
          "type": "integer",
          "minimum": 1,
          "description": "APB1 prescaler"
        },
        "apb2_prescaler": {
          "type": "integer",
          "minimum": 1,
          "description": "APB2 prescaler"
        },
        "flash_latency": {
          "type": "integer",
          "minimum": 0,
          "description": "Flash wait states"
        }
      }
    },
    "build": {
      "type": "object",
      "required": ["linker_script", "startup_source", "toolchain_file"],
      "additionalProperties": false,
      "properties": {
        "linker_script": {
          "type": "string",
          "pattern": "^boards/[a-z0-9_]+/.+\\.(ld|lds)$",
          "description": "Workspace-relative linker script path"
        },
        "startup_source": {
          "type": "string",
          "pattern": "^src/.+\\.cpp$",
          "description": "Workspace-relative startup source path"
        },
        "toolchain_file": {
          "type": "string",
          "pattern": "^cmake/.+\\.cmake$",
          "description": "Workspace-relative CMake toolchain file"
        },
        "default_build_type": {
          "type": "string",
          "enum": ["Debug", "Release", "RelWithDebInfo", "MinSizeRel"],
          "default": "Release"
        },
        "supports_rtos": {
          "type": "boolean",
          "default": true
        },
        "supported_examples": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9_./-]+$"
          }
        }
      }
    },
    "tooling": {
      "type": "object",
      "required": ["flash", "debug"],
      "additionalProperties": false,
      "properties": {
        "flash": {
          "type": "object",
          "required": ["command"],
          "additionalProperties": false,
          "properties": {
            "command": {
              "type": "string",
              "enum": ["st-flash", "openocd"]
            },
            "binary_format": {
              "type": "string",
              "enum": ["bin", "elf"],
              "default": "bin"
            },
            "load_address": {
              "type": "string",
              "pattern": "^0x[0-9A-Fa-f]+$",
              "description": "Flash load address for raw binaries"
            },
            "openocd_target": {
              "type": "string",
              "pattern": "^[a-z0-9_]+$",
              "description": "OpenOCD target cfg basename"
            },
            "openocd_interface": {
              "type": "string",
              "enum": ["stlink", "cmsis-dap", "jlink"],
              "description": "OpenOCD interface cfg basename"
            },
            "openocd_interface_cfg": {
              "type": "string",
              "pattern": "^interface/.+\\.cfg$",
              "description": "Explicit OpenOCD interface cfg path"
            }
          },
          "allOf": [
            {
              "if": {
                "properties": { "command": { "const": "st-flash" } }
              },
              "then": {
                "required": ["load_address"]
              }
            },
            {
              "if": {
                "properties": { "command": { "const": "openocd" } }
              },
              "then": {
                "required": ["openocd_target"],
                "anyOf": [
                  { "required": ["openocd_interface"] },
                  { "required": ["openocd_interface_cfg"] }
                ]
              }
            }
          ]
        },
        "debug": {
          "type": "object",
          "required": ["transport"],
          "additionalProperties": false,
          "properties": {
            "transport": {
              "type": "string",
              "enum": ["stlink", "cmsis-dap", "jlink", "none"]
            },
            "probe": {
              "type": "string"
            },
            "swd_frequency_hz": {
              "type": "integer",
              "minimum": 1000
            }
          }
        }
      }
    },
    "leds": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "port", "pin"],
        "additionalProperties": false,
        "properties": {
          "name": {
            "type": "string",
            "pattern": "^[a-z_][a-z0-9_]*$"
          },
          "color": {
            "type": "string",
            "enum": ["red", "green", "blue", "yellow", "orange", "white"]
          },
          "port": {
            "type": "string",
            "pattern": "^(GPIO[A-K]|PIO[A-E])$"
          },
          "pin": {
            "type": "integer",
            "minimum": 0,
            "maximum": 31
          },
          "active_high": {
            "type": "boolean",
            "default": true
          },
          "description": {
            "type": "string"
          }
        }
      }
    },
    "buttons": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "port", "pin"],
        "additionalProperties": false,
        "properties": {
          "name": {
            "type": "string",
            "pattern": "^[a-z_][a-z0-9_]*$"
          },
          "port": {
            "type": "string",
            "pattern": "^(GPIO[A-K]|PIO[A-E])$"
          },
          "pin": {
            "type": "integer",
            "minimum": 0,
            "maximum": 31
          },
          "active_high": {
            "type": "boolean",
            "default": false
          },
          "pull": {
            "type": "string",
            "enum": ["none", "up", "down"],
            "default": "none"
          },
          "description": {
            "type": "string"
          }
        }
      }
    },
    "uart": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "instance", "tx_port", "tx_pin"],
        "additionalProperties": false,
        "properties": {
          "name": {
            "type": "string",
            "pattern": "^[a-z_][a-z0-9_]*$"
          },
          "instance": {
            "type": "string"
          },
          "tx_port": {
            "type": "string",
            "pattern": "^(GPIO[A-K]|PIO[A-E])$"
          },
          "tx_pin": {
            "type": "integer",
            "minimum": 0,
            "maximum": 31
          },
          "rx_port": {
            "type": "string",
            "pattern": "^(GPIO[A-K]|PIO[A-E])$"
          },
          "rx_pin": {
            "type": "integer",
            "minimum": 0,
            "maximum": 31
          },
          "baud_rate": {
            "type": "integer",
            "default": 115200
          },
          "description": {
            "type": "string"
          }
        }
      }
    },
    "spi": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "name",
          "instance",
          "sck_port",
          "sck_pin",
          "mosi_port",
          "mosi_pin",
          "miso_port",
          "miso_pin"
        ],
        "additionalProperties": false,
        "properties": {
          "name": {
            "type": "string",
            "pattern": "^[a-z_][a-z0-9_]*$"
          },
          "instance": {
            "type": "string"
          },
          "sck_port": {
            "type": "string",
            "pattern": "^(GPIO[A-K]|PIO[A-E])$"
          },
          "sck_pin": {
            "type": "integer",
            "minimum": 0,
            "maximum": 31
          },
          "mosi_port": {
            "type": "string",
            "pattern": "^(GPIO[A-K]|PIO[A-E])$"
          },
          "mosi_pin": {
            "type": "integer",
            "minimum": 0,
            "maximum": 31
          },
          "miso_port": {
            "type": "string",
            "pattern": "^(GPIO[A-K]|PIO[A-E])$"
          },
          "miso_pin": {
            "type": "integer",
            "minimum": 0,
            "maximum": 31
          },
          "description": {
            "type": "string"
          }
        }
      }
    },
    "i2c": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "instance", "scl_port", "scl_pin", "sda_port", "sda_pin"],
        "additionalProperties": false,
        "properties": {
          "name": {
            "type": "string",
            "pattern": "^[a-z_][a-z0-9_]*$"
          },
          "instance": {
            "type": "string"
          },
          "scl_port": {
            "type": "string",
            "pattern": "^(GPIO[A-K]|PIO[A-E])$"
          },
          "scl_pin": {
            "type": "integer",
            "minimum": 0,
            "maximum": 31
          },
          "sda_port": {
            "type": "string",
            "pattern": "^(GPIO[A-K]|PIO[A-E])$"
          },
          "sda_pin": {
            "type": "integer",
            "minimum": 0,
            "maximum": 31
          },
          "speed_hz": {
            "type": "integer",
            "enum": [100000, 400000, 1000000],
            "default": 100000
          },
          "description": {
            "type": "string"
          }
        }
      }
    }
  }
}
