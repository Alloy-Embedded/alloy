{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/lgili/corezero/schemas/board-config.json",
  "title": "MicroCore Board Configuration",
  "description": "JSON Schema for MicroCore board configuration YAML files",
  "type": "object",
  "required": ["board", "platform", "mcu", "clock", "leds"],
  "properties": {
    "board": {
      "type": "object",
      "required": ["name", "vendor", "version"],
      "properties": {
        "name": {
          "type": "string",
          "description": "Board name (e.g., 'Nucleo-F401RE')"
        },
        "vendor": {
          "type": "string",
          "description": "Board manufacturer (e.g., 'STMicroelectronics')"
        },
        "version": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+\\.\\d+$",
          "description": "Board hardware revision (semver format)"
        },
        "description": {
          "type": "string",
          "description": "Human-readable board description"
        },
        "url": {
          "type": "string",
          "format": "uri",
          "description": "URL to board documentation/product page"
        }
      }
    },
    "platform": {
      "type": "string",
      "enum": ["stm32f0", "stm32f1", "stm32f4", "stm32f7", "stm32g0", "stm32g4", "stm32h7", "same70", "host"],
      "description": "MicroCore platform identifier"
    },
    "mcu": {
      "type": "object",
      "required": ["part_number", "architecture"],
      "properties": {
        "part_number": {
          "type": "string",
          "description": "Full MCU part number (e.g., 'STM32F401RET6')"
        },
        "architecture": {
          "type": "string",
          "enum": ["cortex-m0", "cortex-m0+", "cortex-m3", "cortex-m4", "cortex-m7", "cortex-m33"],
          "description": "ARM Cortex-M architecture"
        },
        "flash_kb": {
          "type": "integer",
          "minimum": 16,
          "description": "Flash memory size in KB"
        },
        "ram_kb": {
          "type": "integer",
          "minimum": 4,
          "description": "RAM size in KB"
        },
        "frequency_mhz": {
          "type": "integer",
          "minimum": 1,
          "description": "Maximum CPU frequency in MHz"
        }
      }
    },
    "clock": {
      "type": "object",
      "required": ["source", "system_clock_hz"],
      "properties": {
        "source": {
          "type": "string",
          "enum": ["HSI", "HSE", "PLL", "RC"],
          "description": "Primary clock source"
        },
        "system_clock_hz": {
          "type": "integer",
          "minimum": 1000000,
          "description": "Target system clock frequency in Hz"
        },
        "hse_hz": {
          "type": "integer",
          "description": "External crystal frequency in Hz (if HSE is used)"
        },
        "pll": {
          "type": "object",
          "description": "PLL configuration (platform-specific)",
          "properties": {
            "m": {"type": "integer", "minimum": 1},
            "n": {"type": "integer", "minimum": 1},
            "p": {"type": "integer", "minimum": 1},
            "q": {"type": "integer", "minimum": 1},
            "r": {"type": "integer", "minimum": 1}
          }
        },
        "ahb_prescaler": {
          "type": "integer",
          "minimum": 1,
          "description": "AHB bus prescaler"
        },
        "apb1_prescaler": {
          "type": "integer",
          "minimum": 1,
          "description": "APB1 bus prescaler"
        },
        "apb2_prescaler": {
          "type": "integer",
          "minimum": 1,
          "description": "APB2 bus prescaler"
        },
        "flash_latency": {
          "type": "integer",
          "minimum": 0,
          "description": "Flash wait states"
        }
      }
    },
    "leds": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "port", "pin"],
        "properties": {
          "name": {
            "type": "string",
            "pattern": "^[a-z_][a-z0-9_]*$",
            "description": "LED identifier (C++ compatible name)"
          },
          "color": {
            "type": "string",
            "enum": ["red", "green", "blue", "yellow", "orange", "white"],
            "description": "LED color"
          },
          "port": {
            "type": "string",
            "pattern": "^GPIO[A-K]$",
            "description": "GPIO port (e.g., 'GPIOA')"
          },
          "pin": {
            "type": "integer",
            "minimum": 0,
            "maximum": 15,
            "description": "GPIO pin number (0-15)"
          },
          "active_high": {
            "type": "boolean",
            "default": true,
            "description": "True if LED is on when pin is HIGH"
          },
          "description": {
            "type": "string",
            "description": "Human-readable description"
          }
        }
      }
    },
    "buttons": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "port", "pin"],
        "properties": {
          "name": {
            "type": "string",
            "pattern": "^[a-z_][a-z0-9_]*$",
            "description": "Button identifier (C++ compatible name)"
          },
          "port": {
            "type": "string",
            "pattern": "^GPIO[A-K]$",
            "description": "GPIO port (e.g., 'GPIOC')"
          },
          "pin": {
            "type": "integer",
            "minimum": 0,
            "maximum": 15,
            "description": "GPIO pin number (0-15)"
          },
          "active_high": {
            "type": "boolean",
            "default": false,
            "description": "True if button pressed = HIGH"
          },
          "pull": {
            "type": "string",
            "enum": ["none", "up", "down"],
            "default": "none",
            "description": "Internal pull resistor configuration"
          },
          "description": {
            "type": "string",
            "description": "Human-readable description"
          }
        }
      }
    },
    "uart": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "instance", "tx_port", "tx_pin"],
        "properties": {
          "name": {
            "type": "string",
            "pattern": "^[a-z_][a-z0-9_]*$",
            "description": "UART identifier (e.g., 'console', 'debug')"
          },
          "instance": {
            "type": "string",
            "description": "UART/USART peripheral instance (e.g., 'USART2')"
          },
          "tx_port": {
            "type": "string",
            "pattern": "^GPIO[A-K]$",
            "description": "TX pin GPIO port"
          },
          "tx_pin": {
            "type": "integer",
            "minimum": 0,
            "maximum": 15,
            "description": "TX pin number"
          },
          "rx_port": {
            "type": "string",
            "pattern": "^GPIO[A-K]$",
            "description": "RX pin GPIO port (optional for TX-only)"
          },
          "rx_pin": {
            "type": "integer",
            "minimum": 0,
            "maximum": 15,
            "description": "RX pin number (optional for TX-only)"
          },
          "baud_rate": {
            "type": "integer",
            "default": 115200,
            "description": "Default baud rate"
          },
          "description": {
            "type": "string",
            "description": "Human-readable description"
          }
        }
      }
    },
    "spi": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "instance", "sck_port", "sck_pin", "mosi_port", "mosi_pin", "miso_port", "miso_pin"],
        "properties": {
          "name": {
            "type": "string",
            "pattern": "^[a-z_][a-z0-9_]*$"
          },
          "instance": {
            "type": "string"
          },
          "sck_port": {"type": "string", "pattern": "^GPIO[A-K]$"},
          "sck_pin": {"type": "integer", "minimum": 0, "maximum": 15},
          "mosi_port": {"type": "string", "pattern": "^GPIO[A-K]$"},
          "mosi_pin": {"type": "integer", "minimum": 0, "maximum": 15},
          "miso_port": {"type": "string", "pattern": "^GPIO[A-K]$"},
          "miso_pin": {"type": "integer", "minimum": 0, "maximum": 15},
          "description": {"type": "string"}
        }
      }
    },
    "i2c": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "instance", "scl_port", "scl_pin", "sda_port", "sda_pin"],
        "properties": {
          "name": {
            "type": "string",
            "pattern": "^[a-z_][a-z0-9_]*$"
          },
          "instance": {
            "type": "string"
          },
          "scl_port": {"type": "string", "pattern": "^GPIO[A-K]$"},
          "scl_pin": {"type": "integer", "minimum": 0, "maximum": 15},
          "sda_port": {"type": "string", "pattern": "^GPIO[A-K]$"},
          "sda_pin": {"type": "integer", "minimum": 0, "maximum": 15},
          "speed_hz": {
            "type": "integer",
            "enum": [100000, 400000, 1000000],
            "default": 100000,
            "description": "I2C speed: 100kHz (standard), 400kHz (fast), 1MHz (fast+)"
          },
          "description": {"type": "string"}
        }
      }
    }
  }
}
