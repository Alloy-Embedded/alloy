{
  "$schema": "https://alloy-rs.dev/schemas/board-manifest/v1.json",
  "board_id": "nucleo_f401re",
  "display_name": "Nucleo-F401RE",
  "vendor": "st",
  "family": "stm32f4",
  "device": "stm32f401re",
  "arch": "cortex-m4",
  "linker_script": "STM32F401RET6.ld",
  "board_header": "boards/nucleo_f401re/board.hpp",
  "toolchain": "arm-none-eabi",
  "mcu": "STM32F401RET6",
  "flash_size_bytes": 524288,
  "debug": {
    "probe": "stlink",
    "openocd_cfg": "interface/stlink.cfg target/stm32f4x.cfg",
    "stm32_programmer": true
  },
  "uart": {
    "debug": { "peripheral": "USART2", "tx": "PA2", "rx": "PA3", "baud": 115200 }
  },
  "serial_globs": ["/dev/cu.usbmodem*", "/dev/ttyACM*", "/dev/cu.usbserial*"],
  "leds": [
    { "name": "ld2", "pin": "PA5", "active_high": true }
  ],
  "buttons": [
    { "name": "b1", "pin": "PC13", "active_low": true }
  ],
  "clock_profiles": ["default_hse_pll_84mhz"],
  "firmware_targets": [
    "blink", "time_probe", "uart_logger", "watchdog_probe",
    "rtc_probe", "timer_pwm_probe", "analog_probe", "dma_probe"
  ],
  "bundle_target": "stm32f4_hardware_validation_bundle",
  "build_dir_suffix": "hw/f401",
  "mcuboot": {
    "primary_offset": "0x08020000",
    "primary_size_bytes": 131072,
    "secondary_offset": "0x08040000",
    "boot_size_bytes": 131072
  },
  "tier": 1,
  "notes": "ST Nucleo-F401RE; Cortex-M4 with FPU; 512 KB flash (variable-size sectors); USB FS available on PA11/PA12."
}
