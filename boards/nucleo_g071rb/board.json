{
  "schema": "alloy.board.v1",
  "id": "nucleo_g071rb",
  "name": "ST Nucleo-G071RB",
  "chip": "st/stm32g071rb",
  "clock_profile": "pll_64mhz",
  "roles": {
    "led": {
      "pin": "pa5",
      "active": "high",
      "label": "LD4 (green, D13)"
    },
    "button": {
      "pin": "pc13",
      "active": "low",
      "label": "B1 USER"
    },
    "debug_uart": {
      "peripheral": "usart2",
      "tx": "pa2",
      "rx": "pa3",
      "baud": 115200,
      "label": "ST-Link VCP"
    },
    "watchdog": {
      "peripheral": "iwdg",
      "timeout_ms": 4000,
      "label": "IWDG (LSI ~32 kHz, runtime-configured, ~32 s max)"
    },
    "led_pwm": {
      "peripheral": "tim2",
      "channel": 1,
      "pin": "pa5",
      "label": "LD4 via TIM2_CH1 (AF2)"
    },
    "adc": {
      "peripheral": "adc",
      "label": "internal vref/temp channels"
    },
    "i2c": {
      "peripheral": "i2c1",
      "scl": "pb8",
      "sda": "pb9",
      "label": "Arduino D15/D14 (AF6, internal pull-ups)"
    },
    "spi": {
      "peripheral": "spi1",
      "sck": "pb3",
      "miso": "pb4",
      "mosi": "pb5",
      "label": "SPI1 on PB3/PB4/PB5 (Arduino D3/D5/D4, morpho CN10) — keeps LD4/PA5 free; set hardware-proven by old-alloy lite_hal_probe"
    }
  },
  "probe": {
    "kind": "stlink",
    "runner": "probe-rs",
    "chip_id": "STM32G071RBTx"
  }
}
