{
  "schema": "alloy.board.v1",
  "id": "same70_xplained",
  "name": "Microchip SAM E70 Xplained",
  "chip": "microchip/atsame70q21",
  "clock_profile": "plla_150mhz",
  "roles": {
    "led": {
      "pin": "pc8",
      "active": "low",
      "label": "LED0 (green)"
    },
    "button": {
      "pin": "pa11",
      "active": "low",
      "pull": "up",
      "label": "SW0 USER"
    },
    "debug_uart": {
      "peripheral": "usart1",
      "tx": "pb4",
      "rx": "pa21",
      "baud": 115200,
      "label": "EDBG VCP"
    },
    "i2c": {
      "peripheral": "twihs0",
      "scl": "pa4",
      "sda": "pa3",
      "label": "Xplained EXT/Arduino I2C (TWIHS0, function A)"
    },
    "adc": {
      "peripheral": "afec0",
      "label": "internal temp sensor ch11"
    },
    "spi": {
      "peripheral": "spi0",
      "sck": "pd22",
      "miso": "pd20",
      "mosi": "pd21",
      "label": "SPI0 on EXT1/Arduino headers (SPCK=PD22, MISO=PD20, MOSI=PD21, function B); CS software PD25 (EXT1 pin 15, NPCS1 como GPIO)",
      "cs": "pd25"
    },
    "eeprom": {
      "bus": "i2c",
      "kind": "at24mac402",
      "addr": "0x57",
      "id_addr": "0x5F",
      "page_size": 16,
      "bytes": 256,
      "wp": "pc11",
      "label": "AT24MAC402 U600: EEPROM 256B @0x57, bloco identidade @0x5F (EUI-48 em 0x9A, serial em 0x80), WP em PC11 (baixo = gravavel); 0x37 e o alias de write-protect do mesmo chip"
    },
    "ethernet": {
      "peripheral": "gmac",
      "phy": {
        "kind": "ksz8081",
        "addr": 0,
        "mode": "rmii"
      },
      "label": "onboard 10/100 Ethernet: GMAC + KSZ8081RNACA PHY (RMII, addr 0, reset PC10, RJ45 J500)",
      "reset_pin": "pc10",
      "rmii_pins": [
        "pd0",
        "pd1",
        "pd2",
        "pd3",
        "pd4",
        "pd5",
        "pd6",
        "pd7",
        "pd8",
        "pd9"
      ],
      "rmii_af": 0
    }
  },
  "probe": {
    "kind": "cmsis-dap",
    "runner": "openocd",
    "chip_id": "ATSAME70Q21B"
  }
}
