namespace alloy::device::selected {

inline constexpr bool available = @ALLOY_DEVICE_CONTRACT_AVAILABLE_INT@ != 0;
inline constexpr bool runtime_available = @ALLOY_DEVICE_RUNTIME_LITE_AVAILABLE_INT@ != 0;
inline constexpr std::string_view vendor = "@ALLOY_DEVICE_SELECTED_VENDOR@";
inline constexpr std::string_view family = "@ALLOY_DEVICE_SELECTED_FAMILY@";
