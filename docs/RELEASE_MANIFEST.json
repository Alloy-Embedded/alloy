    "rtc": {
      "tier": "representative",
      "required_gates": [
        "descriptor-contract-smoke",
        "host-mmio",
        "hardware-spot-check"
      ]
    },
    "watchdog": {
      "tier": "representative",
      "required_gates": [
        "descriptor-contract-smoke",
        "host-mmio",
        "hardware-spot-check"
      ]
    },
    "adc": {
      "tier": "representative",
      "required_gates": [
        "descriptor-contract-smoke",
        "hardware-spot-check"
      ]
    },
    "dac": {
      "tier": "representative",
      "required_gates": [
        "descriptor-contract-smoke",
        "hardware-spot-check"
      ]
    },
    "low-power": {
      "tier": "representative",
