{
  "schema_version": 1,
  "alloy_devices": {
    "policy": "pinned-commit",
    "ref": "fa0630fe1501e7435463c1a2f2df4e9858e507b4",
    "compatibility_note": "Alloy releases are validated against this published alloy-devices commit. Updating the commit requires updating this manifest, the workflow pins, and rerunning the foundational release gates."
  },
  "support_tiers": [
    "foundational",
    "representative",
    "experimental",
    "deprecated"
  ],
  "release_gates": {
    "runtime-device-boundary": {
      "kind": "script",
      "command": "python3 scripts/check_runtime_device_boundary.py"
    },
    "release-discipline": {
      "kind": "script",
      "command": "python3 scripts/check_release_discipline.py"
    },
    "blocking-only-path": {
      "kind": "script",
      "command": "python3 scripts/check_blocking_only_path.py"
    },
    "alloyctl-tooling-parity": {
      "kind": "script",
      "command": "python3 scripts/check_alloyctl_tooling_parity.py"
    },
    "descriptor-contract-smoke": {
      "kind": "build",
      "target": "alloy-device-contract-smoke"
    },
    "host-mmio": {
      "kind": "ctest-label",
      "label": "host-mmio"
    },
    "renode-runtime-validation": {
      "kind": "ctest-preset",
      "presets": [
        "same70-runtime-validation",
        "stm32g0-runtime-validation",
        "stm32f4-runtime-validation"
      ]
    },
    "same70-zero-overhead": {
      "kind": "ctest-preset",
      "preset": "same70-zero-overhead"
    },
    "foundational-example-coverage": {
      "kind": "build-targets",
      "notes": "Required example coverage is declared per foundational board in this manifest and reviewed in the release checklist."
    },
    "hardware-spot-check": {
      "kind": "checklist",
      "checklists": [
        "tests/hardware/same70/CHECKLIST.md",
        "tests/hardware/stm32g0/CHECKLIST.md",
        "tests/hardware/stm32f4/CHECKLIST.md"
      ],
      "notes": "Representative on-silicon validation recorded per foundational board. Manual lab evidence, not CI-executed."
    }
  },
  "boards": {
    "same70_xplained": {
      "tier": "foundational",
      "required_gates": [
        "runtime-device-boundary",
        "release-discipline",
        "descriptor-contract-smoke",
        "host-mmio",
        "renode-runtime-validation",
        "same70-zero-overhead",
        "foundational-example-coverage"
      ],
      "required_examples": [
        "blink",
        "time_probe",
        "uart_logger",
        "dma_probe",
        "async_uart_timeout"
      ],
      "notes": "Primary foundational Microchip validation board. async_uart_timeout is the canonical runtime async-model completion+timeout example."
    },
    "nucleo_g071rb": {
      "tier": "foundational",
      "required_gates": [
        "runtime-device-boundary",
        "release-discipline",
        "descriptor-contract-smoke",
        "host-mmio",
        "renode-runtime-validation",
        "foundational-example-coverage"
      ],
      "required_examples": [
        "blink",
        "time_probe"
      ],
      "notes": "Primary foundational STM32G0 validation board."
    },
    "nucleo_f401re": {
      "tier": "foundational",
      "required_gates": [
        "runtime-device-boundary",
        "release-discipline",
        "descriptor-contract-smoke",
        "host-mmio",
        "renode-runtime-validation",
        "foundational-example-coverage"
      ],
      "required_examples": [
        "blink",
        "time_probe"
      ],
      "notes": "Primary foundational STM32F4 validation board."
    },
    "nucleo_g0b1re": {
      "tier": "experimental",
      "required_gates": [
        "foundational-example-coverage"
      ],
      "required_examples": [
        "blink"
      ],
      "notes": "Build-covered board that is not yet part of the foundational runtime-validation ladder."
    }
  },
  "peripheral_classes": {
    "runtime-device-boundary": {
      "tier": "foundational",
      "required_gates": [
        "runtime-device-boundary",
        "descriptor-contract-smoke"
      ]
    },
    "clock-reset-startup": {
      "tier": "foundational",
      "required_gates": [
        "descriptor-contract-smoke",
        "host-mmio",
        "renode-runtime-validation"
      ]
    },
    "gpio": {
      "tier": "foundational",
