        "descriptor-contract-smoke",
        "hardware-spot-check"
      ]
    },
    "timer": {
      "tier": "representative",
      "required_gates": [
        "descriptor-contract-smoke",
        "hardware-spot-check"
      ]
    },
    "pwm": {
      "tier": "representative",
      "required_gates": [
