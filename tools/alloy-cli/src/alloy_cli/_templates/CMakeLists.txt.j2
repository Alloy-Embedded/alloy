cmake_minimum_required(VERSION 3.25)

# Generated by `alloy new` for board {{ board }}.
# The active Alloy SDK path is baked in below; override with -DALLOY_ROOT=... if needed.

set(ALLOY_BOARD "{{ board }}" CACHE STRING "Target Alloy board")
set(ALLOY_ROOT "{{ alloy_root }}" CACHE PATH "Path to the Alloy runtime checkout")

if(NOT EXISTS "${ALLOY_ROOT}/CMakeLists.txt")
    message(FATAL_ERROR
        "ALLOY_ROOT does not point at a valid Alloy checkout: ${ALLOY_ROOT}\n"
        "Reinstall the SDK with `alloy sdk install <version>` or pass -DALLOY_ROOT=<path>.")
endif()

project({{ project }} LANGUAGES C CXX ASM)

add_subdirectory(${ALLOY_ROOT} ${CMAKE_BINARY_DIR}/_alloy)

add_executable({{ project }} src/main.cpp)
target_link_libraries({{ project }} PRIVATE alloy::alloy)
