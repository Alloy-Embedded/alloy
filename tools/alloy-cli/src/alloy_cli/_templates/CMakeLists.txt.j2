cmake_minimum_required(VERSION 3.25)

# Generated by `alloy new` for {{ display_name }}.
# This project owns its board: edit board/ to change pins and peripherals.
# The active Alloy SDK path is baked in below; override with -DALLOY_ROOT=... if needed.
# See docs/CUSTOM_BOARDS.md inside the alloy runtime for the contract.

set(ALLOY_ROOT "{{ alloy_root }}" CACHE PATH "Path to the Alloy runtime checkout")

if(NOT EXISTS "${ALLOY_ROOT}/CMakeLists.txt")
    message(FATAL_ERROR
        "ALLOY_ROOT does not point at a valid Alloy checkout: ${ALLOY_ROOT}\n"
        "Reinstall the SDK with `alloy sdk install <version>` or pass -DALLOY_ROOT=<path>.")
endif()

# Custom-board contract -- declared before add_subdirectory(alloy) so the runtime
# manifest reads them. Edit board/ files to change hardware mappings.
set(ALLOY_BOARD "custom" CACHE STRING "" FORCE)
set(ALLOY_CUSTOM_BOARD_HEADER  "${CMAKE_CURRENT_SOURCE_DIR}/board/{{ board_header_name }}"
    CACHE FILEPATH "" FORCE)
set(ALLOY_CUSTOM_LINKER_SCRIPT "${CMAKE_CURRENT_SOURCE_DIR}/board/{{ linker_script_name }}"
    CACHE FILEPATH "" FORCE)
set(ALLOY_DEVICE_VENDOR "{{ vendor }}" CACHE STRING "" FORCE)
set(ALLOY_DEVICE_FAMILY "{{ family }}" CACHE STRING "" FORCE)
set(ALLOY_DEVICE_NAME   "{{ device }}" CACHE STRING "" FORCE)
set(ALLOY_DEVICE_ARCH   "{{ arch }}"   CACHE STRING "" FORCE)
{% if mcu %}set(ALLOY_DEVICE_MCU    "{{ mcu }}"    CACHE STRING "" FORCE){% endif %}
{% if flash_size_bytes %}set(ALLOY_FLASH_SIZE_BYTES {{ flash_size_bytes }} CACHE STRING "" FORCE){% endif %}

# Tell the alloy build where to find this project's board sources (board.cpp,
# syscalls.cpp). Without this, alloy would look under boards/custom inside its
# tree, which does not exist.
set(ALLOY_BOARD_SOURCE_DIR "${CMAKE_CURRENT_SOURCE_DIR}/board" CACHE PATH "" FORCE)

project({{ project }} LANGUAGES C CXX ASM)

add_subdirectory(${ALLOY_ROOT} ${CMAKE_BINARY_DIR}/_alloy)

set({{ project }}_SOURCES src/main.cpp)
{% for src in board_sources %}list(APPEND {{ project }}_SOURCES board/{{ src }})
{% endfor %}
add_executable({{ project }} ${ {{ project }}_SOURCES })
target_link_libraries({{ project }} PRIVATE alloy::alloy)
