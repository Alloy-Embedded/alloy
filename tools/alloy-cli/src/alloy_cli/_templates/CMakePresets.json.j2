{
    "version": 6,
    "cmakeMinimumRequired": { "major": 3, "minor": 25, "patch": 0 },
    "configurePresets": [
        {
            "name": "debug",
            "displayName": "{{ board }} (Debug)",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build/debug",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "ALLOY_BOARD": "{{ board }}",
                "ALLOY_ROOT": "{{ alloy_root }}"{% if toolchain_file %},
                "CMAKE_TOOLCHAIN_FILE": "{{ toolchain_file }}"{% endif %}
            }{% if toolchain_bin %},
            "environment": {
                "PATH": "{{ toolchain_bin }}:$penv{PATH}"
            }{% endif %}
        },
        {
            "name": "release",
            "inherits": "debug",
            "displayName": "{{ board }} (Release)",
            "binaryDir": "${sourceDir}/build/release",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "MinSizeRel"
            }
        }
    ],
    "buildPresets": [
        { "name": "debug", "configurePreset": "debug" },
        { "name": "release", "configurePreset": "release" }
    ]
}
