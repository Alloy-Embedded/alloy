{
    "version": "0.2.0",
    "configurations": [
{% if has_openocd %}        {
            "name": "Debug ({{ board }} via OpenOCD)",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/debug/{{ project }}.elf",
            "cwd": "${workspaceFolder}",
            "MIMode": "gdb",
            "miDebuggerPath": "{{ gdb_path }}",
            "miDebuggerServerAddress": "localhost:3333",
            "preLaunchTask": "alloy: build",
            "postDebugTask": "",
            "setupCommands": [
                { "text": "set architecture arm" },
                { "text": "target extended-remote localhost:3333" },
                { "text": "monitor reset halt" },
                { "text": "load" }
            ]
        }
{% else %}        {
            "name": "Attach (no probe configured)",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/debug/{{ project }}.elf",
            "cwd": "${workspaceFolder}",
            "MIMode": "gdb",
            "miDebuggerPath": "{{ gdb_path }}",
            "preLaunchTask": "alloy: build",
            "setupCommands": [{ "text": "set architecture arm" }]
        }
{% endif %}    ]
}
