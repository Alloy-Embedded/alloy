 *   SYSCLK: VCO / P = {{ ((board.clock.hse_hz / board.clock.pll.m) * board.clock.pll.n) | int }} Hz / {{ board.clock.pll.p }} = {{ board.clock.system_clock_hz }} Hz
{% if board.clock.pll.q %}
 *   USB:    VCO / Q = {{ ((board.clock.hse_hz / board.clock.pll.m) * board.clock.pll.n) | int }} Hz / {{ board.clock.pll.q }} = {{ (((board.clock.hse_hz / board.clock.pll.m) * board.clock.pll.n) / board.clock.pll.q) | int }} Hz
{% endif %}
{% endif %}
{% endif %}
 *
 * Bus Clocks:
