/**
 * @brief GPIO Hardware Policy for STM32-style GPIO
 *
 * Register Layout (STM32):
 * - MODER:   Mode register (input/output/AF/analog)
 * - OTYPER:  Output type (push-pull/open-drain)
 * - OSPEEDR: Output speed
 * - PUPDR:   Pull-up/pull-down
 * - IDR:     Input data register
 * - ODR:     Output data register
 * - BSRR:    Bit set/reset register (atomic)
 * - LCKR:    Lock register
 * - AFRL/H:  Alternate function registers
 *
 * @tparam BASE_ADDR GPIO port base address
 * @tparam PORT_CHAR Port character ('A', 'B', 'C', etc.)
 */
template <uint32_t BASE_ADDR, char PORT_CHAR>
struct {{ platform.name }}GpioHardwarePolicy {
    // ========================================================================
    // Type Definitions
    // ========================================================================

    using RegisterType = {{ gpio.register_type }};

    // ========================================================================
    // Compile-Time Constants
    // ========================================================================

    static constexpr uint32_t base_address = BASE_ADDR;
    static constexpr char port_char = PORT_CHAR;
    static constexpr uint32_t pins_per_port = {{ gpio.pins_per_port }};

    // Mode values
    static constexpr uint32_t MODE_INPUT = 0;
    static constexpr uint32_t MODE_OUTPUT = 1;
    static constexpr uint32_t MODE_AF = 2;
    static constexpr uint32_t MODE_ANALOG = 3;

    // Output type values
    static constexpr uint32_t OTYPE_PUSH_PULL = 0;
    static constexpr uint32_t OTYPE_OPEN_DRAIN = 1;

    // Output speed values
    static constexpr uint32_t OSPEED_LOW = 0;
    static constexpr uint32_t OSPEED_MEDIUM = 1;
    static constexpr uint32_t OSPEED_HIGH = 2;
    static constexpr uint32_t OSPEED_VERY_HIGH = 3;

    // Pull-up/pull-down values
    static constexpr uint32_t PUPD_NONE = 0;
    static constexpr uint32_t PUPD_PULL_UP = 1;
    static constexpr uint32_t PUPD_PULL_DOWN = 2;

    // ========================================================================
    // Hardware Accessor
    // ========================================================================

    /**
     * @brief Get pointer to GPIO registers
     *
     * @return Pointer to hardware registers
     */
    static inline volatile RegisterType* hw() {
        #ifdef ALLOY_GPIO_MOCK_HW
            return ALLOY_GPIO_MOCK_HW();  // Test hook
        #else
            return reinterpret_cast<volatile RegisterType*>(BASE_ADDR);
        #endif
    }

    // ========================================================================
    // Pin Configuration Methods
    // ========================================================================

    /**
     * @brief Set pin mode (input/output/AF/analog)
     *
     * @param pin Pin number (0-15)
     * @param mode Mode value (MODE_INPUT, MODE_OUTPUT, MODE_AF, MODE_ANALOG)
     */
    static inline void set_mode(u8 pin, u32 mode) {
        const u32 shift = pin * 2;
        const u32 mask = 0x3 << shift;
        hw()->MODER = (hw()->MODER & ~mask) | ((mode & 0x3) << shift);
    }

    /**
     * @brief Set output type (push-pull/open-drain)
     *
     * @param pin Pin number (0-15)
     * @param otype Output type (OTYPE_PUSH_PULL, OTYPE_OPEN_DRAIN)
     */
    static inline void set_output_type(u8 pin, u32 otype) {
        if (otype == OTYPE_OPEN_DRAIN) {
            hw()->OTYPER |= (1 << pin);
        } else {
            hw()->OTYPER &= ~(1 << pin);
        }
    }

    /**
     * @brief Set output speed
     *
     * @param pin Pin number (0-15)
     * @param speed Speed value (OSPEED_LOW, OSPEED_MEDIUM, OSPEED_HIGH, OSPEED_VERY_HIGH)
     */
    static inline void set_output_speed(u8 pin, u32 speed) {
        const u32 shift = pin * 2;
        const u32 mask = 0x3 << shift;
        hw()->OSPEEDR = (hw()->OSPEEDR & ~mask) | ((speed & 0x3) << shift);
    }

    /**
     * @brief Set pull-up/pull-down
     *
     * @param pin Pin number (0-15)
     * @param pupd Pull-up/down value (PUPD_NONE, PUPD_PULL_UP, PUPD_PULL_DOWN)
     */
    static inline void set_pull(u8 pin, u32 pupd) {
        const u32 shift = pin * 2;
        const u32 mask = 0x3 << shift;
        hw()->PUPDR = (hw()->PUPDR & ~mask) | ((pupd & 0x3) << shift);
    }

    /**
     * @brief Set alternate function
     *
     * @param pin Pin number (0-15)
     * @param af Alternate function number (0-15)
     */
    static inline void set_alternate_function(u8 pin, u8 af) {
        if (pin < 8) {
            // AFRL (pins 0-7)
            const u32 shift = pin * 4;
            const u32 mask = 0xF << shift;
            hw()->AFRL = (hw()->AFRL & ~mask) | ((af & 0xF) << shift);
        } else {
            // AFRH (pins 8-15)
            const u32 shift = (pin - 8) * 4;
            const u32 mask = 0xF << shift;
            hw()->AFRH = (hw()->AFRH & ~mask) | ((af & 0xF) << shift);
        }
    }

    // ========================================================================
    // Pin I/O Methods
    // ========================================================================

    /**
     * @brief Set pin high
     *
     * @param pin Pin number (0-15)
     */
    static inline void set(u8 pin) {
        hw()->BSRR = (1 << pin);  // Atomic set
    }

    /**
     * @brief Set pin low
     *
     * @param pin Pin number (0-15)
     */
    static inline void clear(u8 pin) {
        hw()->BSRR = (1 << (pin + 16));  // Atomic reset
    }

    /**
     * @brief Toggle pin
     *
     * @param pin Pin number (0-15)
     */
    static inline void toggle(u8 pin) {
        hw()->ODR ^= (1 << pin);
    }

    /**
     * @brief Read pin state
     *
     * @param pin Pin number (0-15)
     * @return true if pin is high, false if low
     */
    static inline bool read(u8 pin) {
        return (hw()->IDR & (1 << pin)) != 0;
    }

    /**
     * @brief Write pin state
     *
     * @param pin Pin number (0-15)
     * @param value true for high, false for low
     */
    static inline void write(u8 pin, bool value) {
        if (value) {
            set(pin);
        } else {
            clear(pin);
        }
    }

    // ========================================================================
    // Port-Wide Methods
    // ========================================================================

    /**
     * @brief Read entire port
     *
     * @return Port state (16 bits)
     */
    static inline u16 read_port() {
        return static_cast<u16>(hw()->IDR & 0xFFFF);
    }

    /**
     * @brief Write entire port
     *
     * @param value Port value (16 bits)
     */
    static inline void write_port(u16 value) {
        hw()->ODR = value;
    }

    /**
     * @brief Set multiple pins high
     *
     * @param mask Bit mask of pins to set
     */
    static inline void set_mask(u16 mask) {
        hw()->BSRR = mask;
    }

    /**
     * @brief Clear multiple pins low
     *
     * @param mask Bit mask of pins to clear
     */
    static inline void clear_mask(u16 mask) {
        hw()->BSRR = (static_cast<u32>(mask) << 16);
    }
};

