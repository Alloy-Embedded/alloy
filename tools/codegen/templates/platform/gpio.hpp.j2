/**
 * @brief GPIO Hardware Policy for SAM-style GPIO (PIO)
 *
 * Register Layout (SAM):
 * - PER:   PIO Enable Register
 * - PDR:   PIO Disable Register
 * - PSR:   PIO Status Register
 * - OER:   Output Enable Register
 * - ODR:   Output Disable Register
 * - OSR:   Output Status Register
 * - SODR:  Set Output Data Register
 * - CODR:  Clear Output Data Register
 * - ODSR:  Output Data Status Register
 * - PDSR:  Pin Data Status Register
 *
 * @tparam BASE_ADDR PIO port base address
 * @tparam PORT_CHAR Port character ('A', 'B', 'C', 'D', etc.)
 */
template <uint32_t BASE_ADDR, char PORT_CHAR>
struct {{ platform.name }}GpioHardwarePolicy {
    // ========================================================================
    // Type Definitions
    // ========================================================================

    using RegisterType = {{ gpio.register_type }};

    // ========================================================================
    // Compile-Time Constants
    // ========================================================================

    static constexpr uint32_t base_address = BASE_ADDR;
    static constexpr char port_char = PORT_CHAR;
    static constexpr uint32_t pins_per_port = {{ gpio.pins_per_port }};

    // ========================================================================
    // Hardware Accessor
    // ========================================================================

    /**
     * @brief Get pointer to PIO registers
     *
     * @return Pointer to hardware registers
     */
    static inline volatile RegisterType* hw() {
        #ifdef ALLOY_GPIO_MOCK_HW
            return ALLOY_GPIO_MOCK_HW();  // Test hook
        #else
            return reinterpret_cast<volatile RegisterType*>(BASE_ADDR);
        #endif
    }

    // ========================================================================
    // Pin Configuration Methods
    // ========================================================================

    /**
     * @brief Enable PIO control on pin
     *
     * @param pin Pin number (0-31)
     */
    static inline void enable_pio(u8 pin) {
        hw()->PER = (1 << pin);  // Write-only, set bit
    }

    /**
     * @brief Disable PIO control on pin (peripheral control)
     *
     * @param pin Pin number (0-31)
     */
    static inline void disable_pio(u8 pin) {
        hw()->PDR = (1 << pin);  // Write-only, clear bit
    }

    /**
     * @brief Set pin as output
     *
     * @param pin Pin number (0-31)
     */
    static inline void set_output(u8 pin) {
        hw()->OER = (1 << pin);  // Write-only, enable output
    }

    /**
     * @brief Set pin as input
     *
     * @param pin Pin number (0-31)
     */
    static inline void set_input(u8 pin) {
        hw()->ODR = (1 << pin);  // Write-only, disable output
    }

    // ========================================================================
    // Pin I/O Methods
    // ========================================================================

    /**
     * @brief Set pin high
     *
     * @param pin Pin number (0-31)
     */
    static inline void set(u8 pin) {
        hw()->SODR = (1 << pin);  // Write-only, set output
    }

    /**
     * @brief Set pin low
     *
     * @param pin Pin number (0-31)
     */
    static inline void clear(u8 pin) {
        hw()->CODR = (1 << pin);  // Write-only, clear output
    }

    /**
     * @brief Toggle pin
     *
     * @param pin Pin number (0-31)
     */
    static inline void toggle(u8 pin) {
        if (hw()->ODSR & (1 << pin)) {
            clear(pin);
        } else {
            set(pin);
        }
    }

    /**
     * @brief Read pin state
     *
     * @param pin Pin number (0-31)
     * @return true if pin is high, false if low
     */
    static inline bool read(u8 pin) {
        return (hw()->PDSR & (1 << pin)) != 0;
    }

    /**
     * @brief Write pin state
     *
     * @param pin Pin number (0-31)
     * @param value true for high, false for low
     */
    static inline void write(u8 pin, bool value) {
        if (value) {
            set(pin);
        } else {
            clear(pin);
        }
    }

    // ========================================================================
    // Port-Wide Methods
    // ========================================================================

    /**
     * @brief Read entire port
     *
     * @return Port state (32 bits)
     */
    static inline u32 read_port() {
        return hw()->PDSR;
    }

    /**
     * @brief Set multiple pins high
     *
     * @param mask Bit mask of pins to set
     */
    static inline void set_mask(u32 mask) {
        hw()->SODR = mask;
    }

    /**
     * @brief Clear multiple pins low
     *
     * @param mask Bit mask of pins to clear
     */
    static inline void clear_mask(u32 mask) {
        hw()->CODR = mask;
    }
};

