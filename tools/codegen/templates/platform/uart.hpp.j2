/**
 * @brief UART Hardware Policy for STM32-style UART/USART
 *
 * Register Layout (STM32):
 * - SR:    Status register (TXE, RXNE, TC, ORE, etc.)
 * - DR:    Data register (TX/RX)
 * - BRR:   Baud rate register
 * - CR1:   Control register 1 (UE, TE, RE, RXNEIE, TCIE)
 * - CR2:   Control register 2 (STOP bits, etc.)
 * - CR3:   Control register 3 (DMA, etc.)
 *
 * @tparam BASE_ADDR UART peripheral base address
 * @tparam PERIPH_CLOCK_HZ Peripheral clock frequency for baud rate calculation
 */
template <uint32_t BASE_ADDR, uint32_t PERIPH_CLOCK_HZ>
struct {{ platform.name }}UartHardwarePolicy {
    // ========================================================================
    // Type Definitions
    // ========================================================================

    using RegisterType = {{ uart.register_type }};

    // ========================================================================
    // Compile-Time Constants
    // ========================================================================

    static constexpr uint32_t base_address = BASE_ADDR;
    static constexpr uint32_t peripheral_clock_hz = PERIPH_CLOCK_HZ;

    // CR1 bits
    static constexpr uint32_t CR1_UE = (1 << 13);     // USART enable
    static constexpr uint32_t CR1_TE = (1 << 3);      // Transmitter enable
    static constexpr uint32_t CR1_RE = (1 << 2);      // Receiver enable
    static constexpr uint32_t CR1_RXNEIE = (1 << 5);  // RXNE interrupt enable
    static constexpr uint32_t CR1_TCIE = (1 << 6);    // TC interrupt enable
    static constexpr uint32_t CR1_TXEIE = (1 << 7);   // TXE interrupt enable
    static constexpr uint32_t CR1_M = (1 << 12);      // Word length (0=8bits, 1=9bits)
    static constexpr uint32_t CR1_PCE = (1 << 10);    // Parity control enable
    static constexpr uint32_t CR1_PS = (1 << 9);      // Parity selection (0=even, 1=odd)

    // CR2 bits
    static constexpr uint32_t CR2_STOP_1BIT = (0 << 12);
    static constexpr uint32_t CR2_STOP_2BIT = (2 << 12);

    // SR bits
    static constexpr uint32_t SR_TXE = (1 << 7);   // Transmit data register empty
    static constexpr uint32_t SR_TC = (1 << 6);    // Transmission complete
    static constexpr uint32_t SR_RXNE = (1 << 5);  // Read data register not empty
    static constexpr uint32_t SR_ORE = (1 << 3);   // Overrun error
    static constexpr uint32_t SR_FE = (1 << 1);    // Framing error
    static constexpr uint32_t SR_PE = (1 << 0);    // Parity error

    // ========================================================================
    // Hardware Accessor
    // ========================================================================

    /**
     * @brief Get pointer to UART registers
     *
     * @return Pointer to hardware registers
     */
    static inline volatile RegisterType* hw() {
        #ifdef ALLOY_UART_MOCK_HW
            return ALLOY_UART_MOCK_HW();  // Test hook
        #else
            return reinterpret_cast<volatile RegisterType*>(BASE_ADDR);
        #endif
    }

    // ========================================================================
    // Configuration Methods
    // ========================================================================

    /**
     * @brief Enable UART peripheral
     */
    static inline void enable() {
        hw()->CR1 |= CR1_UE;
    }

    /**
     * @brief Disable UART peripheral
     */
    static inline void disable() {
        hw()->CR1 &= ~CR1_UE;
    }

    /**
     * @brief Enable transmitter
     */
    static inline void enable_tx() {
        hw()->CR1 |= CR1_TE;
    }

    /**
     * @brief Disable transmitter
     */
    static inline void disable_tx() {
        hw()->CR1 &= ~CR1_TE;
    }

    /**
     * @brief Enable receiver
     */
    static inline void enable_rx() {
        hw()->CR1 |= CR1_RE;
    }

    /**
     * @brief Disable receiver
     */
    static inline void disable_rx() {
        hw()->CR1 &= ~CR1_RE;
    }

    /**
     * @brief Set baud rate
     *
     * @param baudrate Desired baud rate
     */
    static inline void set_baudrate(u32 baudrate) {
        // BRR = PERIPH_CLOCK_HZ / baudrate
        u32 brr = (PERIPH_CLOCK_HZ + (baudrate / 2)) / baudrate;
        hw()->BRR = brr;
    }

    /**
     * @brief Configure for 8N1 (8 data bits, no parity, 1 stop bit)
     */
    static inline void configure_8n1() {
        hw()->CR1 &= ~(CR1_M | CR1_PCE);  // 8 bits, no parity
        hw()->CR2 &= ~(3 << 12);          // Clear stop bits
        hw()->CR2 |= CR2_STOP_1BIT;       // 1 stop bit
    }

    /**
     * @brief Configure for 8E1 (8 data bits, even parity, 1 stop bit)
     */
    static inline void configure_8e1() {
        hw()->CR1 &= ~CR1_M;             // 8 bits
        hw()->CR1 |= CR1_PCE;            // Enable parity
        hw()->CR1 &= ~CR1_PS;            // Even parity
        hw()->CR2 &= ~(3 << 12);         // Clear stop bits
        hw()->CR2 |= CR2_STOP_1BIT;      // 1 stop bit
    }

    // ========================================================================
    // Data Transfer Methods
    // ========================================================================

    /**
     * @brief Check if transmit register is empty
     *
     * @return true if TXE flag is set
     */
    static inline bool is_tx_ready() {
        return (hw()->SR & SR_TXE) != 0;
    }

    /**
     * @brief Check if receive register has data
     *
     * @return true if RXNE flag is set
     */
    static inline bool is_rx_ready() {
        return (hw()->SR & SR_RXNE) != 0;
    }

    /**
     * @brief Check if transmission is complete
     *
     * @return true if TC flag is set
     */
    static inline bool is_tx_complete() {
        return (hw()->SR & SR_TC) != 0;
    }

    /**
     * @brief Write byte to data register
     *
     * @param data Byte to transmit
     *
     * @note Does not check TXE flag - caller must ensure TX is ready
     */
    static inline void write_byte(u8 data) {
        hw()->DR = data;
    }

    /**
     * @brief Read byte from data register
     *
     * @return Received byte
     *
     * @note Does not check RXNE flag - caller must ensure RX has data
     */
    static inline u8 read_byte() {
        return static_cast<u8>(hw()->DR & 0xFF);
    }

    // ========================================================================
    // Error Handling
    // ========================================================================

    /**
     * @brief Check for overrun error
     *
     * @return true if overrun occurred
     */
    static inline bool has_overrun_error() {
        return (hw()->SR & SR_ORE) != 0;
    }

    /**
     * @brief Check for framing error
     *
     * @return true if framing error occurred
     */
    static inline bool has_framing_error() {
        return (hw()->SR & SR_FE) != 0;
    }

    /**
     * @brief Check for parity error
     *
     * @return true if parity error occurred
     */
    static inline bool has_parity_error() {
        return (hw()->SR & SR_PE) != 0;
    }

    /**
     * @brief Clear error flags
     *
     * @note Reading DR clears errors on STM32
     */
    static inline void clear_errors() {
        [[maybe_unused]] volatile u32 dummy = hw()->SR;
        dummy = hw()->DR;
    }

    // ========================================================================
    // Interrupt Management
    // ========================================================================

    /**
     * @brief Enable RX interrupt
     */
    static inline void enable_rx_interrupt() {
        hw()->CR1 |= CR1_RXNEIE;
    }

    /**
     * @brief Disable RX interrupt
     */
    static inline void disable_rx_interrupt() {
        hw()->CR1 &= ~CR1_RXNEIE;
    }

    /**
     * @brief Enable TX interrupt
     */
    static inline void enable_tx_interrupt() {
        hw()->CR1 |= CR1_TXEIE;
    }

    /**
     * @brief Disable TX interrupt
     */
    static inline void disable_tx_interrupt() {
        hw()->CR1 &= ~CR1_TXEIE;
    }
};

{% elif uart.style == 'sam' %}
// ============================================================================
// SAM-Style UART Hardware Policy
// ============================================================================

/**
 * @brief UART Hardware Policy for SAM-style UART
 *
 * Register Layout (SAM):
 * - CR:    Control register (write-only commands)
 * - MR:    Mode register (parity, data bits, etc.)
 * - SR:    Status register (TXRDY, RXRDY, etc.)
 * - THR:   Transmit holding register (write-only)
 * - RHR:   Receive holding register (read-only)
 * - BRGR:  Baud rate generator register
 * - IER:   Interrupt enable register (write-only)
 * - IDR:   Interrupt disable register (write-only)
 * - IMR:   Interrupt mask register (read-only)
 *
 * @tparam BASE_ADDR UART peripheral base address
 * @tparam PERIPH_CLOCK_HZ Peripheral clock frequency for baud rate calculation
 */
template <uint32_t BASE_ADDR, uint32_t PERIPH_CLOCK_HZ>
struct {{ platform.name }}UartHardwarePolicy {
    // ========================================================================
    // Type Definitions
    // ========================================================================

    using RegisterType = {{ uart.register_type }};

    // ========================================================================
    // Compile-Time Constants
    // ========================================================================

    static constexpr uint32_t base_address = BASE_ADDR;
    static constexpr uint32_t peripheral_clock_hz = PERIPH_CLOCK_HZ;

    // CR commands (write-only)
    static constexpr uint32_t CR_RSTRX = (1 << 2);   // Reset receiver
    static constexpr uint32_t CR_RSTTX = (1 << 3);   // Reset transmitter
    static constexpr uint32_t CR_RXEN = (1 << 4);    // Receiver enable
    static constexpr uint32_t CR_RXDIS = (1 << 5);   // Receiver disable
    static constexpr uint32_t CR_TXEN = (1 << 6);    // Transmitter enable
    static constexpr uint32_t CR_TXDIS = (1 << 7);   // Transmitter disable
    static constexpr uint32_t CR_RSTSTA = (1 << 8);  // Reset status bits

    // MR bits
    static constexpr uint32_t MR_PAR_NONE = (4 << 9);   // No parity
    static constexpr uint32_t MR_PAR_EVEN = (0 << 9);   // Even parity
    static constexpr uint32_t MR_PAR_ODD = (1 << 9);    // Odd parity
    static constexpr uint32_t MR_CHMODE_NORMAL = (0 << 14);  // Normal mode

    // SR bits
    static constexpr uint32_t SR_RXRDY = (1 << 0);   // Receiver ready
    static constexpr uint32_t SR_TXRDY = (1 << 1);   // Transmitter ready
    static constexpr uint32_t SR_OVRE = (1 << 5);    // Overrun error
    static constexpr uint32_t SR_FRAME = (1 << 6);   // Framing error
    static constexpr uint32_t SR_PARE = (1 << 7);    // Parity error
    static constexpr uint32_t SR_TXEMPTY = (1 << 9); // Transmitter empty

    // Interrupt bits
    static constexpr uint32_t INT_RXRDY = (1 << 0);
    static constexpr uint32_t INT_TXRDY = (1 << 1);
    static constexpr uint32_t INT_OVRE = (1 << 5);
    static constexpr uint32_t INT_FRAME = (1 << 6);
    static constexpr uint32_t INT_PARE = (1 << 7);

    // ========================================================================
    // Hardware Accessor
    // ========================================================================

    /**
     * @brief Get pointer to UART registers
     *
     * @return Pointer to hardware registers
     */
    static inline volatile RegisterType* hw() {
        #ifdef ALLOY_UART_MOCK_HW
            return ALLOY_UART_MOCK_HW();  // Test hook
        #else
            return reinterpret_cast<volatile RegisterType*>(BASE_ADDR);
        #endif
    }

    // ========================================================================
    // Configuration Methods
    // ========================================================================

    /**
     * @brief Reset and enable UART
     */
    static inline void enable() {
        hw()->CR = CR_RSTRX | CR_RSTTX | CR_RXEN | CR_TXEN;
    }

    /**
     * @brief Disable UART
     */
    static inline void disable() {
        hw()->CR = CR_RXDIS | CR_TXDIS;
    }

    /**
     * @brief Enable transmitter
     */
    static inline void enable_tx() {
        hw()->CR = CR_TXEN;
    }

    /**
     * @brief Disable transmitter
     */
    static inline void disable_tx() {
        hw()->CR = CR_TXDIS;
    }

    /**
     * @brief Enable receiver
     */
    static inline void enable_rx() {
        hw()->CR = CR_RXEN;
    }

    /**
     * @brief Disable receiver
     */
    static inline void disable_rx() {
        hw()->CR = CR_RXDIS;
    }

    /**
     * @brief Set baud rate
     *
     * @param baudrate Desired baud rate
     */
    static inline void set_baudrate(u32 baudrate) {
        // CD = PERIPH_CLOCK_HZ / (16 * baudrate)
        u32 cd = (PERIPH_CLOCK_HZ / (16 * baudrate));
        hw()->BRGR = cd;
    }

    /**
     * @brief Configure for 8N1 (8 data bits, no parity, 1 stop bit)
     */
    static inline void configure_8n1() {
        hw()->MR = MR_PAR_NONE | MR_CHMODE_NORMAL;
    }

    /**
     * @brief Configure for 8E1 (8 data bits, even parity, 1 stop bit)
     */
    static inline void configure_8e1() {
        hw()->MR = MR_PAR_EVEN | MR_CHMODE_NORMAL;
    }

    // ========================================================================
    // Data Transfer Methods
    // ========================================================================

    /**
     * @brief Check if transmit register is ready
     *
     * @return true if TXRDY flag is set
     */
    static inline bool is_tx_ready() {
        return (hw()->SR & SR_TXRDY) != 0;
    }

    /**
     * @brief Check if receive register has data
     *
     * @return true if RXRDY flag is set
     */
    static inline bool is_rx_ready() {
        return (hw()->SR & SR_RXRDY) != 0;
    }

    /**
     * @brief Check if transmission is complete
     *
     * @return true if TXEMPTY flag is set
     */
    static inline bool is_tx_complete() {
        return (hw()->SR & SR_TXEMPTY) != 0;
    }

    /**
     * @brief Write byte to transmit holding register
     *
     * @param data Byte to transmit
     *
     * @note Does not check TXRDY flag - caller must ensure TX is ready
     */
    static inline void write_byte(u8 data) {
        hw()->THR = data;
    }

    /**
     * @brief Read byte from receive holding register
     *
     * @return Received byte
     *
     * @note Does not check RXRDY flag - caller must ensure RX has data
     */
    static inline u8 read_byte() {
        return static_cast<u8>(hw()->RHR & 0xFF);
    }

    // ========================================================================
    // Error Handling
    // ========================================================================

    /**
     * @brief Check for overrun error
     *
     * @return true if overrun occurred
     */
    static inline bool has_overrun_error() {
        return (hw()->SR & SR_OVRE) != 0;
    }

    /**
     * @brief Check for framing error
     *
     * @return true if framing error occurred
     */
    static inline bool has_framing_error() {
        return (hw()->SR & SR_FRAME) != 0;
    }

    /**
     * @brief Check for parity error
     *
     * @return true if parity error occurred
     */
    static inline bool has_parity_error() {
        return (hw()->SR & SR_PARE) != 0;
    }

    /**
     * @brief Clear error flags
     */
    static inline void clear_errors() {
        hw()->CR = CR_RSTSTA;
    }

    // ========================================================================
    // Interrupt Management
    // ========================================================================

    /**
     * @brief Enable RX interrupt
     */
    static inline void enable_rx_interrupt() {
        hw()->IER = INT_RXRDY;
    }

    /**
     * @brief Disable RX interrupt
     */
    static inline void disable_rx_interrupt() {
        hw()->IDR = INT_RXRDY;
    }

    /**
     * @brief Enable TX interrupt
     */
    static inline void enable_tx_interrupt() {
        hw()->IER = INT_TXRDY;
    }

    /**
     * @brief Disable TX interrupt
     */
    static inline void disable_tx_interrupt() {
        hw()->IDR = INT_TXRDY;
    }
};

