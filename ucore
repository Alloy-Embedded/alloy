class UCoreBuilder:
    """MicroCore unified builder"""

    def __init__(self):
        self.root_dir = Path(__file__).parent.resolve()
        self.examples_dir = self.root_dir / "examples"
        self.boards_dir = self.root_dir / "boards"
        self.toolchain_file = self.root_dir / "cmake" / "toolchains" / "arm-none-eabi.cmake"

    def get_examples(self) -> List[str]:
        """Get list of available examples"""
        if not self.examples_dir.exists():
            return []

        examples = []
        for item in self.examples_dir.iterdir():
            if item.is_dir() and (item / "CMakeLists.txt").exists():
                examples.append(item.name)
            # Also check for nested examples (like rtos/simple_tasks)
            elif item.is_dir():
                for subitem in item.iterdir():
                    if subitem.is_dir() and (subitem / "CMakeLists.txt").exists():
                        examples.append(f"{item.name}/{subitem.name}")

        return sorted(examples)

    def load_board_yaml(self, board_id: str) -> Optional[Dict]:
        """Load board configuration from YAML file"""
        yaml_path = self.boards_dir / board_id / "board.yaml"
        if not yaml_path.exists():
            return None

        try:
            with open(yaml_path, 'r') as f:
                return yaml.safe_load(f)
        except Exception as e:
            print_error(f"Failed to load {yaml_path}: {e}")
            return None

    def get_boards_from_yaml(self) -> Dict[str, Dict]:
        """Get all boards that have board.yaml files"""
        boards = {}

        if not self.boards_dir.exists():
            return boards

        for board_dir in self.boards_dir.iterdir():
            if not board_dir.is_dir():
                continue

            yaml_path = board_dir / "board.yaml"
            if yaml_path.exists():
                config = self.load_board_yaml(board_dir.name)
                if config:
                    boards[board_dir.name] = config

        return boards

    def list_boards(self):
        """List all supported boards"""
        print_header("Supported Boards")

        # Get boards from YAML files
        yaml_boards = self.get_boards_from_yaml()

        # Merge with hardcoded boards (for backward compatibility)
        all_boards = set(BOARDS.keys()) | set(yaml_boards.keys())

        for board_id in sorted(all_boards):
            # Try YAML first, fall back to hardcoded
            yaml_config = yaml_boards.get(board_id)
            hardcoded_info = BOARDS.get(board_id)

            print(f"{Colors.OKBLUE}{Colors.BOLD}{board_id}{Colors.ENDC}", end="")

            # Indicate source of configuration
            if yaml_config and hardcoded_info:
                print(f" {Colors.OKGREEN}[YAML + Build]{Colors.ENDC}")
            elif yaml_config:
                print(f" {Colors.OKGREEN}[YAML]{Colors.ENDC}")
            elif hardcoded_info:
                print(f" {Colors.WARNING}[Legacy]{Colors.ENDC}")

            if yaml_config:
                # Display YAML configuration
                board_info = yaml_config.get('board', {})
                mcu_info = yaml_config.get('mcu', {})
                clock_info = yaml_config.get('clock', {})

                print(f"  Name:         {board_info.get('name', 'N/A')}")
                print(f"  Vendor:       {board_info.get('vendor', 'N/A')}")
                print(f"  MCU:          {mcu_info.get('part_number', 'N/A')}")
                print(f"  Architecture: {mcu_info.get('architecture', 'N/A')}")
                freq_mhz = clock_info.get('system_clock_hz', 0) / 1_000_000
                print(f"  Frequency:    {freq_mhz:.0f} MHz")
                print(f"  Platform:     {yaml_config.get('platform', 'N/A')}")

                # Show flash/RAM if available
                if mcu_info.get('flash_kb'):
                    print(f"  Flash:        {mcu_info['flash_kb']} KB")
                if mcu_info.get('ram_kb'):
                    print(f"  RAM:          {mcu_info['ram_kb']} KB")

                # Show flash tool from hardcoded if available
                if hardcoded_info:
                    print(f"  Flash tool:   {hardcoded_info['flash_cmd']}")

            elif hardcoded_info:
                # Display legacy hardcoded configuration
                print(f"  Name:         {hardcoded_info['name']}")
                print(f"  MCU:          {hardcoded_info['mcu']}")
                print(f"  Architecture: {hardcoded_info['arch']}")
                print(f"  Frequency:    {hardcoded_info['freq']}")
                print(f"  Flash tool:   {hardcoded_info['flash_cmd']}")

            print()

    def list_examples(self):
        """List all available examples"""
        print_header("Available Examples")

        examples = self.get_examples()
        if not examples:
            print_warning("No examples found")
            return

        for example in examples:
            example_path = self.examples_dir / example
            print(f"  {Colors.OKGREEN}•{Colors.ENDC} {example}")

            # Try to read description from CMakeLists.txt
            cmake_file = example_path / "CMakeLists.txt"
            if cmake_file.exists():
                with open(cmake_file) as f:
                    for line in f:
                        if 'DESCRIPTION' in line and '"' in line:
                            desc = line.split('"')[1]
                            print(f"    {desc}")
                            break
        print()

    def build(self, board: str, example: str, build_type: str = "Release") -> int:
        """Build example for board"""

        # Validate board
        if board not in BOARDS:
            print_error(f"Unknown board: {board}")
            print_info(f"Available boards: {', '.join(BOARDS.keys())}")
            return 1

        # Validate example
        example_path = self.examples_dir / example
        if not example_path.exists() or not (example_path / "CMakeLists.txt").exists():
            print_error(f"Example not found: {example}")
            print_info("Run './ucore list examples' to see available examples")
            return 1

        print_header(f"Building {example} for {board}")

        board_info = BOARDS[board]
        print_info(f"Board: {board_info['name']} ({board_info['mcu']})")
        print_info(f"Example: {example}")
        print_info(f"Build type: {build_type}")
        print()

        # Build directory
        build_dir = self.root_dir / f"build-{board}"

        # Configure
        print(f"{Colors.BOLD}[1/2] Configuring...{Colors.ENDC}")
        configure_cmd = [
            "cmake",
            "-B", str(build_dir),
            f"-DMICROCORE_BOARD={board}",
            "-DMICROCORE_BUILD_TESTS=OFF",
            f"-DCMAKE_TOOLCHAIN_FILE={self.toolchain_file}",
            f"-DCMAKE_BUILD_TYPE={build_type}",
        ]

        result = subprocess.run(configure_cmd, cwd=self.root_dir)
        if result.returncode != 0:
            print_error("Configuration failed")
            return 1

        print_success("Configuration complete")
        print()

        # Build
        print(f"{Colors.BOLD}[2/2] Building...{Colors.ENDC}")

        # Extract example target name (last part of path)
        example_target = example.split('/')[-1]

        build_cmd = [
            "cmake",
            "--build", str(build_dir),
            "--target", example_target,
            "--", "-j4"  # Parallel build
        ]

        result = subprocess.run(build_cmd, cwd=self.root_dir)
        if result.returncode != 0:
            print_error("Build failed")
            return 1

        print_success("Build complete")

        # Show binary info
        bin_file = build_dir / "examples" / example / f"{example_target}.bin"
        elf_file = build_dir / "examples" / example / example_target

        if elf_file.exists():
            size = elf_file.stat().st_size
            print()
            print_info(f"Binary location: {elf_file}")
            print_info(f"Binary size: {size:,} bytes ({size/1024:.1f} KB)")

        return 0

    def flash(self, board: str, example: str, build_type: str = "Release", reset: bool = False) -> int:
        """Build and flash example to board"""

        # Build first
        if self.build(board, example, build_type) != 0:
            return 1

        print()
        print_header(f"Flashing {example} to {board}")

        board_info = BOARDS[board]
        flash_cmd = board_info['flash_cmd']

        # Check if flash tool is available
        if not shutil.which(flash_cmd):
            print_error(f"Flash tool not found: {flash_cmd}")
            print_info("Install flash tools:")
            if flash_cmd == 'st-flash':
                print_info("  macOS:  brew install stlink")
                print_info("  Linux:  apt-get install stlink-tools")
            elif flash_cmd == 'openocd':
                print_info("  macOS:  brew install openocd")
                print_info("  Linux:  apt-get install openocd")
            return 1

        # Determine binary file
        build_dir = self.root_dir / f"build-{board}"
        example_target = example.split('/')[-1]

        print_warning("Connect your board now and press Enter to continue...")
        input()

        success = False

        if flash_cmd == 'st-flash':
            bin_file = build_dir / "examples" / example / f"{example_target}.bin"
            if not bin_file.exists():
                print_error(f"Binary not found: {bin_file}")
                return 1

            # Try normal flash first
            flash_args = board_info['flash_args'](bin_file)
            cmd = [flash_cmd] + flash_args

            print()
            print_info(f"Method 1: Standard flash")
            print_info(f"Command: {' '.join(cmd)}")
            result = subprocess.run(cmd, cwd=self.root_dir)

            if result.returncode == 0:
                success = True
            else:
                # If failed, try with --connect-under-reset
                print()
                print_warning("Standard flash failed, trying with connect-under-reset...")
                print_info("Hold the RESET button on your board, then press Enter...")
                input()

                cmd_reset = [flash_cmd, '--connect-under-reset'] + flash_args
                print_info(f"Command: {' '.join(cmd_reset)}")
                print_warning("Release the RESET button NOW!")

                result = subprocess.run(cmd_reset, cwd=self.root_dir)

                if result.returncode == 0:
                    success = True
                else:
                    # Last resort: try OpenOCD if available
                    if shutil.which('openocd'):
                        print()
                        print_warning("st-flash failed, trying OpenOCD as fallback...")
                        success = self._flash_with_openocd(board_info, bin_file)
                    else:
                        print_error("All flash methods failed")
                        print_info("Troubleshooting tips:")
                        print_info("  1. Check USB connection")
                        print_info("  2. Try a different USB port")
                        print_info("  3. Try holding RESET button while connecting")
                        print_info("  4. Check if board is detected: st-info --probe")
                        return 1

        elif flash_cmd == 'openocd':
            elf_file = build_dir / "examples" / example / example_target
            if not elf_file.exists():
                print_error(f"ELF file not found: {elf_file}")
                return 1

            success = self._flash_with_openocd(board_info, elf_file, is_elf=True)

        else:
            print_error(f"Unsupported flash command: {flash_cmd}")
            return 1

        if success:
            print()
            print_success("Flash complete!")
            print()
            print(f"{Colors.OKGREEN}{Colors.BOLD}🎉 {example} is now running on {board}!{Colors.ENDC}")
            return 0
        else:
            print_error("Flash failed")
            return 1

    def _flash_with_openocd(self, board_info: dict, bin_or_elf_file: Path, is_elf: bool = False) -> bool:
        """Flash using OpenOCD (fallback or primary method)"""
        print()
        print_info("Using OpenOCD for flashing...")

        target = board_info.get('openocd_target', 'stm32f4x')

        if is_elf:
            # ELF file - can program directly
            cmd = [
                'openocd',
                '-f', 'interface/stlink.cfg',
                '-f', f'target/{target}.cfg',
                '-c', 'init',
                '-c', 'reset init',
                '-c', f'program {bin_or_elf_file} verify reset exit'
            ]
        else:
            # Binary file - need to specify address
            cmd = [
                'openocd',
                '-f', 'interface/stlink.cfg',
                '-f', f'target/{target}.cfg',
                '-c', 'init',
                '-c', 'reset init',
                '-c', f'flash write_image erase {bin_or_elf_file} 0x08000000',
                '-c', 'verify_image {bin_or_elf_file} 0x08000000',
                '-c', 'reset run',
                '-c', 'exit'
            ]

        print_info(f"Command: {' '.join(cmd)}")
        result = subprocess.run(cmd, cwd=self.root_dir)

        return result.returncode == 0

    def clean(self, board: Optional[str] = None):
        """Clean build directory"""
        if board:
            if board not in BOARDS:
                print_error(f"Unknown board: {board}")
                return 1

            build_dir = self.root_dir / f"build-{board}"
            if build_dir.exists():
                print_info(f"Cleaning {build_dir}")
                shutil.rmtree(build_dir)
                print_success(f"Cleaned {board} build directory")
            else:
                print_warning(f"Build directory not found: {build_dir}")
        else:
            # Clean all board build directories
            cleaned = False
            for board_id in BOARDS.keys():
                build_dir = self.root_dir / f"build-{board_id}"
                if build_dir.exists():
                    print_info(f"Cleaning {build_dir}")
                    shutil.rmtree(build_dir)
                    cleaned = True

            if cleaned:
                print_success("Cleaned all board build directories")
            else:
                print_warning("No board build directories found")

    def validate_board(self, board: str) -> int:
        """Validate board YAML configuration"""
        print_header(f"Validating Board: {board}")

        yaml_path = self.boards_dir / board / "board.yaml"

        if not yaml_path.exists():
            print_error(f"Board YAML not found: {yaml_path}")
            print_info("Run './ucore list boards' to see available boards")
            return 1

        # Import the board generator for validation
        try:
            sys.path.insert(0, str(self.root_dir / "tools" / "codegen"))
            from cli.generators.board_generator import BoardGenerator

            generator = BoardGenerator()
            valid = generator.validate_yaml(yaml_path)

            if valid:
                print()
                print_success(f"✓ Board configuration is valid!")
                print()

                # Show summary
                config = self.load_board_yaml(board)
                if config:
                    board_info = config.get('board', {})
                    mcu_info = config.get('mcu', {})
                    clock_info = config.get('clock', {})

                    print(f"{Colors.BOLD}Board Summary:{Colors.ENDC}")
                    print(f"  Name:      {board_info.get('name')}")
                    print(f"  Vendor:    {board_info.get('vendor')}")
                    print(f"  MCU:       {mcu_info.get('part_number')}")
                    print(f"  Platform:  {config.get('platform')}")
                    print(f"  Clock:     {clock_info.get('system_clock_hz') / 1_000_000:.0f} MHz")
                    print(f"  LEDs:      {len(config.get('leds', []))}")
                    print(f"  Buttons:   {len(config.get('buttons', []))}")
                    print(f"  UART:      {len(config.get('uart', []))}")
                    print()

                return 0
            else:
                return 1

        except ImportError as e:
            print_error(f"Failed to import board generator: {e}")
            print_info("Make sure you're running from the project root directory")
            return 1
        except Exception as e:
            print_error(f"Validation failed: {e}")
            return 1

    def generate_board(self, board: str) -> int:
        """Generate C++ board configuration from YAML"""
        print_header(f"Generating Board Config: {board}")

        yaml_path = self.boards_dir / board / "board.yaml"

        if not yaml_path.exists():
            print_error(f"Board YAML not found: {yaml_path}")
            print_info("Run './ucore new-board' to create a new board configuration")
            return 1

        # Import the board generator
        try:
            sys.path.insert(0, str(self.root_dir / "tools" / "codegen"))
            from cli.generators.board_generator import BoardGenerator

            generator = BoardGenerator()
            generator.generate_board_config(yaml_path)

            print()
            print_success("✓ Board configuration generated successfully!")
            print_info(f"Output: {yaml_path.parent / 'board_config.hpp'}")
            print()

            return 0

        except ImportError as e:
            print_error(f"Failed to import board generator: {e}")
            return 1
        except Exception as e:
            print_error(f"Generation failed: {e}")
            return 1

    def new_board(self, board_name: str) -> int:
        """Interactive wizard to create a new board configuration"""
        print_header(f"New Board Wizard: {board_name}")

        board_dir = self.boards_dir / board_name
        yaml_path = board_dir / "board.yaml"

        # Check if board already exists
        if board_dir.exists():
            print_error(f"Board directory already exists: {board_dir}")
            return 1

        # Create board directory
        board_dir.mkdir(parents=True, exist_ok=True)
        print_success(f"Created directory: {board_dir}")

        # Interactive prompts
        print()
        print(f"{Colors.BOLD}Board Information{Colors.ENDC}")
        print("Press Enter to use default value shown in [brackets]")
        print()

        def prompt(question: str, default: str = "") -> str:
            if default:
                response = input(f"  {question} [{default}]: ").strip()
                return response if response else default
            else:
                while True:
                    response = input(f"  {question}: ").strip()
                    if response:
                        return response
                    print_warning("  This field is required!")

        # Collect information
        board_display_name = prompt("Board name", board_name.replace('_', ' ').title())
        vendor = prompt("Vendor (e.g., STMicroelectronics)")
        mcu_part = prompt("MCU part number (e.g., STM32F401RET6)")

        # Platform selection
        print()
        print(f"{Colors.BOLD}Select Platform:{Colors.ENDC}")
        platforms = ['stm32f0', 'stm32f1', 'stm32f4', 'stm32f7', 'stm32g0', 'stm32g4', 'stm32h7', 'same70']
        for i, plat in enumerate(platforms, 1):
            print(f"  {i}. {plat}")
        while True:
            try:
                choice = int(prompt("Platform number (1-8)"))
                if 1 <= choice <= len(platforms):
                    platform = platforms[choice - 1]
                    break
            except ValueError:
                pass
            print_warning("  Invalid choice!")

        # Architecture
        print()
        print(f"{Colors.BOLD}Select Architecture:{Colors.ENDC}")
        architectures = ['cortex-m0', 'cortex-m0+', 'cortex-m3', 'cortex-m4', 'cortex-m7', 'cortex-m33']
        for i, arch in enumerate(architectures, 1):
            print(f"  {i}. {arch}")
        while True:
            try:
                choice = int(prompt("Architecture number (1-6)"))
                if 1 <= choice <= len(architectures):
                    architecture = architectures[choice - 1]
                    break
            except ValueError:
                pass
            print_warning("  Invalid choice!")

        # Clock configuration
        print()
        print(f"{Colors.BOLD}Clock Configuration:{Colors.ENDC}")
        clock_freq = int(prompt("System clock frequency (MHz)", "84"))
        has_external_crystal = prompt("Has external crystal? (y/n)", "y").lower() == 'y'

        # LED configuration
        print()
        print(f"{Colors.BOLD}LED Configuration:{Colors.ENDC}")
        led_name = prompt("LED name", "led_green")
        led_port = prompt("LED GPIO port (e.g., GPIOA)", "GPIOA")
        led_pin = int(prompt("LED pin number (0-15)", "5"))
        led_active_high = prompt("LED active high? (y/n)", "y").lower() == 'y'

        # Generate YAML content
        yaml_content = f"""# MicroCore Board Configuration: {board_display_name}

board:
  name: "{board_display_name}"
  vendor: "{vendor}"
  version: "1.0.0"
  description: "{board_display_name} development board"

platform: {platform}

mcu:
  part_number: "{mcu_part}"
  architecture: {architecture}
  frequency_mhz: {clock_freq}

clock:
  source: {"PLL" if has_external_crystal else "HSI"}
  system_clock_hz: {clock_freq * 1_000_000}
"""

        if has_external_crystal:
            yaml_content += f"""  hse_hz: 8000000  # TODO: Update with actual crystal frequency
  pll:
    m: 4   # TODO: Calculate PLL parameters
    n: 168
    p: 4
    q: 7
  ahb_prescaler: 1
  apb1_prescaler: 2
  apb2_prescaler: 1
  flash_latency: 2  # TODO: Update based on frequency
"""

        yaml_content += f"""
leds:
  - name: {led_name}
    port: {led_port}
    pin: {led_pin}
    active_high: {str(led_active_high).lower()}
    description: "User LED"

buttons: []

uart: []
"""

        # Write YAML file
        yaml_path.write_text(yaml_content)
        print()
        print_success(f"✓ Created {yaml_path}")

        # Create placeholder board.hpp
        board_hpp = board_dir / "board.hpp"
