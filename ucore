        """List all supported boards"""
        print_header("Supported Boards")

        boards = self.get_board_registry()
        catalog_loaded = self._load_board_catalog() is not None

        if not boards:
            print_warning("No boards available")
            return

        for board_id in sorted(boards):
            board_info = boards[board_id]
            source = "Metadata" if catalog_loaded else "Legacy"

            print(f"{Colors.OKBLUE}{Colors.BOLD}{board_id}{Colors.ENDC} {Colors.OKGREEN}[{source}]{Colors.ENDC}")
            print(f"  Name:         {board_info.get('name', 'N/A')}")

            vendor = board_info.get("vendor")
            if vendor:
                print(f"  Vendor:       {vendor}")

            print(f"  MCU:          {board_info.get('mcu', 'N/A')}")
            print(f"  Architecture: {board_info.get('arch', 'N/A')}")
            print(f"  Frequency:    {board_info.get('freq', 'N/A')}")

            platform = board_info.get("platform")
            if platform:
                print(f"  Platform:     {platform}")

            flash_kb = board_info.get("flash_kb", 0)
            ram_kb = board_info.get("ram_kb", 0)
            if flash_kb:
                print(f"  Flash:        {flash_kb} KB")
            if ram_kb:
                print(f"  RAM:          {ram_kb} KB")

            print(f"  Flash tool:   {board_info.get('flash_cmd', 'N/A')}")
            print()

    def list_examples(self):
        """List all available examples"""
        print_header("Available Examples")

        examples = self.get_examples()
        if not examples:
            print_warning("No examples found")
            return

        for example_id in sorted(examples.keys()):
            spec = examples[example_id]
            boards = ", ".join(spec["boards"])
            print(f"  {Colors.OKGREEN}•{Colors.ENDC} {example_id}")
            print(f"    Target: {spec['target']}")
            print(f"    Path:   examples/{spec['path']}")
            print(f"    Boards: {boards}")
            if spec.get("description"):
                print(f"    {spec['description']}")
        print()

    def build(
        self,
        board: str,
        example: str,
        build_type: str = "Release",
        non_interactive: bool = False,
    ) -> int:
        """Build example for board"""

        non_interactive = self._non_interactive_enabled(non_interactive)
        board_registry = self.get_board_registry()

        # Validate board
        if board not in board_registry:
            print_error(f"Unknown board: {board}")
            self._print_board_guidance(board)
            return 1

        # Validate example
        examples = self.get_examples()
        example_spec, resolution_error = self.resolve_example(example, examples)
        if resolution_error:
            print_error(resolution_error)
            self._print_example_guidance(example, examples)
            return 1
        if not example_spec:
            print_error(f"Example/target not found: {example}")
            self._print_example_guidance(example, examples)
            return 1

        mapping_error = self._validate_example_mapping(example_spec, examples)
        if mapping_error:
            print_error(mapping_error)
            self._print_example_guidance(example_spec.get("id", example), examples)
            return 1

        if board not in example_spec["boards"]:
            print_error(f"Example '{example_spec['id']}' is not supported on board: {board}")
            print_info(f"Supported boards for this example: {', '.join(example_spec['boards'])}")
            board_suggestions = self._suggestions(board, example_spec["boards"])
            if board_suggestions:
                print_info(f"Did you mean board: {', '.join(board_suggestions)}")
            return 1

        print_header(f"Building {example_spec['id']} for {board}")

        board_info = board_registry[board]
        print_info(f"Board: {board_info['name']} ({board_info['mcu']})")
        print_info(f"Example: {example_spec['id']}")
        print_info(f"Target: {example_spec['target']}")
        print_info(f"Build type: {build_type}")
        if non_interactive:
            print_info("Mode: non-interactive")
        print()

        # Build directory
        build_dir = self.root_dir / f"build-{board}"

        toolchain_path = self.toolchain_file
        toolchain_rel = board_info.get("build", {}).get("toolchain_file", "")
        if isinstance(toolchain_rel, str) and toolchain_rel.strip():
            candidate = self.root_dir / toolchain_rel
            if candidate.exists():
                toolchain_path = candidate
            else:
                print_warning(f"Configured toolchain file not found: {candidate}")

        # Configure
        print(f"{Colors.BOLD}[1/2] Configuring...{Colors.ENDC}")
        configure_cmd = [
            "cmake",
            "-B", str(build_dir),
            f"-DMICROCORE_BOARD={board}",
            "-DMICROCORE_BUILD_TESTS=OFF",
            f"-DCMAKE_TOOLCHAIN_FILE={toolchain_path}",
            f"-DCMAKE_BUILD_TYPE={build_type}",
        ]

        result = subprocess.run(configure_cmd, cwd=self.root_dir)
        if result.returncode != 0:
            print_error("Configuration failed")
            return 1

        print_success("Configuration complete")
        print()

        # Build
        print(f"{Colors.BOLD}[2/2] Building...{Colors.ENDC}")

        build_cmd = [
            "cmake",
            "--build", str(build_dir),
            "--target", example_spec["target"],
            "--", "-j4"  # Parallel build
        ]

        result = subprocess.run(build_cmd, cwd=self.root_dir)
        if result.returncode != 0:
            print_error("Build failed")
            return 1

        print_success("Build complete")

        # Show binary info
        example_path = example_spec["path"]
        example_target = example_spec["target"]
        bin_file = build_dir / "examples" / example_path / f"{example_target}.bin"
        elf_file = build_dir / "examples" / example_path / example_target

        if elf_file.exists():
            size = elf_file.stat().st_size
            print()
            print_info(f"Binary location: {elf_file}")
            print_info(f"Binary size: {size:,} bytes ({size/1024:.1f} KB)")

        return 0

    def flash(
        self,
        board: str,
        example: str,
        build_type: str = "Release",
        reset: bool = False,
        non_interactive: bool = False,
    ) -> int:
        """Build and flash example to board"""

        non_interactive = self._non_interactive_enabled(non_interactive)
        board_registry = self.get_board_registry()

        if board not in board_registry:
            print_error(f"Unknown board: {board}")
            self._print_board_guidance(board)
            return 1

        examples = self.get_examples()
        example_spec, resolution_error = self.resolve_example(example, examples)
        if resolution_error:
            print_error(resolution_error)
            self._print_example_guidance(example, examples)
            return 1
        if not example_spec:
            print_error(f"Example/target not found: {example}")
            self._print_example_guidance(example, examples)
            return 1

        mapping_error = self._validate_example_mapping(example_spec, examples)
        if mapping_error:
            print_error(mapping_error)
            self._print_example_guidance(example_spec.get("id", example), examples)
            return 1

        # Build first
        if self.build(
            board,
            example_spec["id"],
            build_type,
            non_interactive=non_interactive,
        ) != 0:
            return 1

        print()
        print_header(f"Flashing {example_spec['id']} to {board}")

        board_info = board_registry[board]
        flash_cmd = board_info.get("flash_cmd", "")
        flash_format = str(board_info.get("flash_binary_format", "bin")).lower()
        flash_load_address = board_info.get("flash_load_address", "") or "0x08000000"

        # Check if flash tool is available
        if not shutil.which(flash_cmd):
            print_error(f"Flash tool not found: {flash_cmd}")
            print_info("Install flash tools:")
            if flash_cmd == 'st-flash':
                print_info("  macOS:  brew install stlink")
                print_info("  Linux:  apt-get install stlink-tools")
            elif flash_cmd == 'openocd':
                print_info("  macOS:  brew install openocd")
                print_info("  Linux:  apt-get install openocd")
            return 1

        # Determine binary file
        build_dir = self.root_dir / f"build-{board}"
        example_target = example_spec["target"]
        example_path = example_spec["path"]

        if non_interactive:
            print_info("Mode: non-interactive")
            print_info("Skipping connection prompt")
        else:
            print_warning("Connect your board now and press Enter to continue...")
            input()

        success = False

        if flash_cmd == 'st-flash':
            bin_file = build_dir / "examples" / example_path / f"{example_target}.bin"
            if not bin_file.exists():
                print_error(f"Binary not found: {bin_file}")
                return 1

            # Try normal flash first
            flash_args = ['write', str(bin_file), flash_load_address]
            cmd_standard = [flash_cmd] + flash_args
            cmd_reset = [flash_cmd, '--connect-under-reset'] + flash_args

            if reset:
                print()
                print_info("Method: connect-under-reset (--reset)")
                if not non_interactive:
                    print_info("Hold RESET while command runs, then release when programming starts.")
                print_info(f"Command: {' '.join(cmd_reset)}")
                result = subprocess.run(cmd_reset, cwd=self.root_dir)
                success = result.returncode == 0
            else:
                print()
                print_info("Method 1: Standard flash")
                print_info(f"Command: {' '.join(cmd_standard)}")
                result = subprocess.run(cmd_standard, cwd=self.root_dir)
                success = result.returncode == 0

                if not success:
                    if non_interactive:
                        print_error("Standard flash failed in non-interactive mode")
                        print_machine_hint(
                            "interactive_step_required",
                            command="flash",
                            board=board,
                            example=example_spec["id"],
                            guidance="retry_with_reset_or_without_non_interactive",
                        )
                        print_info("Retry with '--reset' or without '--non-interactive'")
                        return 1

                    print()
                    print_warning("Standard flash failed, trying with connect-under-reset...")
                    print_info("Hold the RESET button on your board, then press Enter...")
                    input()
                    print_info(f"Command: {' '.join(cmd_reset)}")
                    print_warning("Release the RESET button NOW!")
                    result = subprocess.run(cmd_reset, cwd=self.root_dir)
                    success = result.returncode == 0

            if not success:
                # Last resort: try OpenOCD if available
                if shutil.which('openocd'):
                    print()
                    print_warning("st-flash failed, trying OpenOCD as fallback...")
                    success = self._flash_with_openocd(board_info, bin_file)
                else:
                    print_error("All flash methods failed")
                    print_info("Troubleshooting tips:")
                    print_info("  1. Check USB connection")
                    print_info("  2. Try a different USB port")
                    print_info("  3. Try holding RESET button while connecting")
                    print_info("  4. Check if board is detected: st-info --probe")
                    return 1

        elif flash_cmd == 'openocd':
            elf_file = build_dir / "examples" / example_path / example_target
            bin_file = build_dir / "examples" / example_path / f"{example_target}.bin"

            image_file = elf_file if flash_format == "elf" else bin_file
            is_elf = flash_format == "elf"

            if not image_file.exists():
                print_error(f"Flash image not found: {image_file}")
                return 1

            success = self._flash_with_openocd(board_info, image_file, is_elf=is_elf)

        else:
            print_error(f"Unsupported flash command: {flash_cmd}")
            return 1

        if success:
            print()
            print_success("Flash complete!")
            print()
            print(f"{Colors.OKGREEN}{Colors.BOLD}🎉 {example_spec['id']} is now running on {board}!{Colors.ENDC}")
            return 0
        else:
            print_error("Flash failed")
            return 1

    def smoke(
        self,
        board: Optional[str] = None,
        build_type: str = "Release",
        non_interactive: bool = False,
        fail_fast: bool = False,
    ) -> int:
        """Run build smoke tests across supported board/example combinations."""

        non_interactive = self._non_interactive_enabled(non_interactive)
        board_registry = self.get_board_registry()

        if board and board not in board_registry:
            print_error(f"Unknown board: {board}")
            self._print_board_guidance(board)
            return 1

        examples = self.get_examples()
        if not examples:
            print_error("No configured examples found for smoke testing")
            return 1

        boards_to_test = [board] if board else sorted(board_registry.keys())
        failures: List[Tuple[str, str, str]] = []
        total = 0
        passed = 0

        print_header("CLI Smoke Matrix")
        print_info(f"Build type: {build_type}")
        if non_interactive:
            print_info("Mode: non-interactive")
        print_info(f"Boards: {', '.join(boards_to_test)}")
        print()

        for board_id in boards_to_test:
            board_examples = sorted(
                spec["id"] for spec in examples.values() if board_id in spec["boards"]
            )

            if not board_examples:
                print_warning(f"No supported examples for board '{board_id}'")
                continue

            for example_id in board_examples:
                example_spec = examples[example_id]
                expected_target = example_spec.get("target", "<unmapped>")
                total += 1
                print_info(
                    f"[{total}] Smoke build: {board_id} -> {example_id} "
                    f"(target: {expected_target})"
                )
                rc = self.build(
                    board_id,
                    example_id,
                    build_type,
                    non_interactive=non_interactive,
                )

                if rc == 0:
                    passed += 1
                else:
                    failures.append((board_id, example_id, expected_target))
                    if fail_fast:
                        print_machine_hint(
                            "smoke_build_failed",
                            board=board_id,
                            example=example_id,
                            expected_target=expected_target,
                        )
                        return 1

                print()

        print_header("Smoke Summary")
        print_info(f"Total combinations: {total}")
        print_info(f"Passed: {passed}")
        print_info(f"Failed: {len(failures)}")

        if failures:
            for failed_board, failed_example, failed_target in failures:
                print_error(
                    f"{failed_board} -> {failed_example} "
                    f"(expected target: {failed_target})"
                )
            print_machine_hint(
                "smoke_matrix_failed",
                total=total,
                passed=passed,
                failed=len(failures),
                failures=[
                    {
                        "board": failed_board,
                        "example": failed_example,
                        "expected_target": failed_target,
                    }
                    for failed_board, failed_example, failed_target in failures
                ],
            )
            return 1

        print_success("All smoke builds passed")
        return 0

    def _flash_with_openocd(self, board_info: dict, bin_or_elf_file: Path, is_elf: bool = False) -> bool:
        """Flash using OpenOCD (fallback or primary method)"""
        print()
        print_info("Using OpenOCD for flashing...")

        target = board_info.get('openocd_target', 'stm32f4x')
        interface = board_info.get('openocd_interface', 'stlink')
        load_address = board_info.get('flash_load_address', '') or '0x08000000'

        interface_cfg = interface if str(interface).endswith(".cfg") else f"interface/{interface}.cfg"
        target_cfg = target if str(target).endswith(".cfg") else f"target/{target}.cfg"

        if is_elf:
            # ELF file - can program directly
            cmd = [
                'openocd',
                '-f', interface_cfg,
                '-f', target_cfg,
                '-c', 'init',
                '-c', 'reset init',
                '-c', f'program {bin_or_elf_file} verify reset exit'
            ]
        else:
            # Binary file - need to specify address
            cmd = [
                'openocd',
                '-f', interface_cfg,
                '-f', target_cfg,
                '-c', 'init',
                '-c', 'reset init',
                '-c', f'flash write_image erase {bin_or_elf_file} {load_address}',
                '-c', f'verify_image {bin_or_elf_file} {load_address}',
                '-c', 'reset run',
                '-c', 'exit'
            ]

        print_info(f"Command: {' '.join(cmd)}")
        result = subprocess.run(cmd, cwd=self.root_dir)

        return result.returncode == 0

    def clean(self, board: Optional[str] = None):
        """Clean build directory"""
        board_registry = self.get_board_registry()

        if board:
            if board not in board_registry:
                print_error(f"Unknown board: {board}")
                self._print_board_guidance(board)
                return 1

            build_dir = self.root_dir / f"build-{board}"
            if build_dir.exists():
                print_info(f"Cleaning {build_dir}")
                shutil.rmtree(build_dir)
                print_success(f"Cleaned {board} build directory")
            else:
                print_warning(f"Build directory not found: {build_dir}")
        else:
            # Clean all board build directories
            cleaned = False
            for board_id in board_registry.keys():
                build_dir = self.root_dir / f"build-{board_id}"
                if build_dir.exists():
                    print_info(f"Cleaning {build_dir}")
                    shutil.rmtree(build_dir)
                    cleaned = True

            if cleaned:
                print_success("Cleaned all board build directories")
            else:
                print_warning("No board build directories found")

