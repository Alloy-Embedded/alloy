class UCoreBuilder:
    """MicroCore unified builder"""

    def __init__(self):
        self.root_dir = Path(__file__).parent.resolve()
        self.examples_dir = self.root_dir / "examples"
        self.boards_dir = self.root_dir / "boards"
        self.toolchain_file = self.root_dir / "cmake" / "toolchains" / "arm-none-eabi.cmake"
        self.board_catalog_path = self.boards_dir / "generated" / "board_catalog.json"
        self._board_catalog_loaded = False
        self._board_catalog_cache: Optional[Dict[str, Any]] = None

    def _load_board_catalog(self) -> Optional[Dict[str, Any]]:
        """Load generated board catalog JSON."""
        if self._board_catalog_loaded:
            return self._board_catalog_cache

        self._board_catalog_loaded = True

        if not self.board_catalog_path.exists():
            self._board_catalog_cache = None
            return None

        try:
            payload = json.loads(self.board_catalog_path.read_text(encoding="utf-8"))
        except Exception as exc:
            print_warning(f"Failed to parse {self.board_catalog_path}: {exc}")
            self._board_catalog_cache = None
            return None

        if not isinstance(payload, dict):
            print_warning(f"Invalid board catalog format: {self.board_catalog_path}")
            self._board_catalog_cache = None
            return None

        schema_version = payload.get("schema_version")
        if schema_version != BOARD_CATALOG_SCHEMA_VERSION:
            print_warning(
                f"Unexpected board catalog schema version '{schema_version}' "
                f"(expected '{BOARD_CATALOG_SCHEMA_VERSION}')"
            )

        boards = payload.get("boards")
        if not isinstance(boards, dict) or not boards:
            print_warning(f"Board catalog has no boards: {self.board_catalog_path}")
            self._board_catalog_cache = None
            return None

        self._board_catalog_cache = payload
        return payload

    def _catalog_board_registry(self) -> Dict[str, Dict[str, Any]]:
        """Build board registry from generated board catalog."""
        catalog = self._load_board_catalog()
        if not catalog:
            return {}

        registry: Dict[str, Dict[str, Any]] = {}
        boards = catalog.get("boards", {})

        for board_id in sorted(boards.keys()):
            raw = boards[board_id]
            mcu = raw.get("mcu", {})
            clock = raw.get("clock", {})
            tooling = raw.get("tooling", {})
            flash = tooling.get("flash", {})
            build = raw.get("build", {})

            registry[board_id] = {
                "id": board_id,
                "name": raw.get("name", board_id),
                "vendor": raw.get("vendor", ""),
                "description": raw.get("description", ""),
                "platform": raw.get("platform", ""),
                "mcu": mcu.get("part_number", ""),
                "arch": mcu.get("architecture_display", mcu.get("architecture", "N/A")),
                "freq": clock.get("frequency_human", "N/A"),
                "flash_kb": mcu.get("flash_kb", 0),
                "ram_kb": mcu.get("ram_kb", 0),
                "flash_cmd": flash.get("command", ""),
                "flash_binary_format": flash.get("binary_format", "bin"),
                "flash_load_address": flash.get("load_address", ""),
                "openocd_target": flash.get("openocd_target", ""),
                "openocd_interface": flash.get("openocd_interface", "stlink"),
                "build": build if isinstance(build, dict) else {},
                "raw": raw,
            }

        return registry

    def _legacy_board_registry(self) -> Dict[str, Dict[str, Any]]:
        """Build board registry from legacy hardcoded table."""
        registry: Dict[str, Dict[str, Any]] = {}
        for board_id, raw in LEGACY_BOARDS.items():
            flash_cmd = raw.get("flash_cmd", "")
            flash_format = "elf" if flash_cmd == "openocd" else "bin"
            flash_interface = "cmsis-dap" if board_id == "same70_xplained" else "stlink"
            flash_address = "0x08000000" if flash_cmd == "st-flash" else ""

            registry[board_id] = {
                "id": board_id,
                "name": raw.get("name", board_id),
                "vendor": "",
                "description": "",
                "platform": "",
                "mcu": raw.get("mcu", "N/A"),
                "arch": raw.get("arch", "N/A"),
                "freq": raw.get("freq", "N/A"),
                "flash_kb": 0,
                "ram_kb": 0,
                "flash_cmd": flash_cmd,
                "flash_binary_format": flash_format,
                "flash_load_address": flash_address,
                "openocd_target": raw.get("openocd_target", ""),
                "openocd_interface": flash_interface,
                "build": {},
                "raw": raw,
            }

        return registry

    def get_board_registry(self) -> Dict[str, Dict[str, Any]]:
        """Get board registry using generated metadata as canonical source."""
        catalog_registry = self._catalog_board_registry()
        if catalog_registry:
            return catalog_registry
        return self._legacy_board_registry()

    def _non_interactive_enabled(self, non_interactive: bool) -> bool:
        """Resolve non-interactive mode from flag or environment."""
        if non_interactive:
            return True

        env_value = os.getenv("UCORE_NON_INTERACTIVE", "").strip().lower()
        return env_value in {"1", "true", "yes", "on"}

    def _suggestions(self, query: str, options: List[str], max_items: int = 3) -> List[str]:
        """Return close matches for a user-provided identifier."""
        unique_options = sorted(set(options))
        return difflib.get_close_matches(query, unique_options, n=max_items, cutoff=0.4)

    def _example_reference_sets(self, examples: Dict[str, Dict]) -> Tuple[List[str], List[str], List[str]]:
        """Collect normalized reference sets for examples."""
        ids = sorted(examples.keys())
        targets = sorted({spec["target"] for spec in examples.values() if spec.get("target")})
        paths = sorted({spec["path"] for spec in examples.values() if spec.get("path")})
        return ids, targets, paths

    def _print_board_guidance(self, board: str):
        """Print actionable board alternatives."""
        valid_boards = sorted(self.get_board_registry().keys())
        suggestions = self._suggestions(board, valid_boards)
        if suggestions:
            print_info(f"Did you mean board: {', '.join(suggestions)}")
        print_info(f"Valid boards: {', '.join(valid_boards)}")

    def _print_example_guidance(self, example_ref: str, examples: Dict[str, Dict]):
        """Print actionable example/target alternatives."""
        example_ids, targets, paths = self._example_reference_sets(examples)
        suggestions = self._suggestions(example_ref, example_ids + targets + paths)
        if suggestions:
            print_info(f"Did you mean: {', '.join(suggestions)}")
        print_info(f"Valid example IDs: {', '.join(example_ids)}")
        print_info(f"Valid target names: {', '.join(targets)}")

    def _validate_example_mapping(self, example_spec: Dict, examples: Dict[str, Dict]) -> Optional[str]:
        """Verify that an example has a canonical target mapping."""
        target = example_spec.get("target")
        if isinstance(target, str) and target.strip():
            return None

        mapped_targets = sorted(spec["target"] for spec in examples.values() if spec.get("target"))
        return (
            f"Example '{example_spec.get('id', '<unknown>')}' has no configured target mapping. "
            f"Available mapped targets: {', '.join(mapped_targets)}"
        )

    def get_examples(self) -> Dict[str, Dict]:
        """Get available examples from explicit catalog plus board metadata."""
        examples: Dict[str, Dict[str, Any]] = {}

        for spec in LEGACY_EXAMPLE_CATALOG:
            example_path = self.examples_dir / spec["path"]
            if not (example_path / "CMakeLists.txt").exists():
                continue

            spec_copy = dict(spec)
            spec_copy["boards"] = sorted(set(spec.get("boards", [])))
            examples[spec_copy["id"]] = spec_copy

        board_registry = self._catalog_board_registry()
        if not board_registry:
            return examples

        # Rebuild board support lists from metadata for deterministic behavior.
        for spec in examples.values():
            spec["boards"] = []

        for board_id, board_info in board_registry.items():
            supported_examples = board_info.get("build", {}).get("supported_examples", [])
            if not isinstance(supported_examples, list):
                continue

            for example_id in supported_examples:
                example_spec = examples.get(example_id)
                if example_spec:
                    example_spec["boards"].append(board_id)

        filtered: Dict[str, Dict[str, Any]] = {}
        for example_id, spec in examples.items():
            spec["boards"] = sorted(set(spec.get("boards", [])))
            if spec["boards"]:
                filtered[example_id] = spec

        return filtered

    def resolve_example(self, example_ref: str, examples: Optional[Dict[str, Dict]] = None) -> Tuple[Optional[Dict], Optional[str]]:
        """
        Resolve user example reference to a catalog entry.

        Supports:
        - Full example ID (recommended), e.g. rtos/simple_tasks
        - Example path when unique, e.g. uart_logger
        - Target name when unique, e.g. rtos_simple_tasks
        """
        if examples is None:
            examples = self.get_examples()

        if example_ref in examples:
            return examples[example_ref], None

        path_matches = [spec for spec in examples.values() if spec["path"] == example_ref]
        if len(path_matches) == 1:
            return path_matches[0], None
        if len(path_matches) > 1:
            choices = ", ".join(sorted(spec["id"] for spec in path_matches))
            return None, f"Ambiguous example '{example_ref}'. Use one of: {choices}"

        target_matches = [spec for spec in examples.values() if spec["target"] == example_ref]
        if len(target_matches) == 1:
            return target_matches[0], None
        if len(target_matches) > 1:
            choices = ", ".join(sorted(spec["id"] for spec in target_matches))
            return None, f"Ambiguous target '{example_ref}'. Use one of: {choices}"

        return None, None

    def load_board_yaml(self, board_id: str) -> Optional[Dict]:
        """Load board configuration from YAML file"""
        yaml_path = self.boards_dir / board_id / "board.yaml"
        if not yaml_path.exists():
            return None

        try:
            with open(yaml_path, 'r') as f:
                return yaml.safe_load(f)
        except Exception as e:
            print_error(f"Failed to load {yaml_path}: {e}")
            return None

    def get_boards_from_yaml(self) -> Dict[str, Dict]:
        """Get all boards that have board.yaml files"""
        boards = {}

        if not self.boards_dir.exists():
            return boards

        for board_dir in self.boards_dir.iterdir():
            if not board_dir.is_dir():
                continue

            yaml_path = board_dir / "board.yaml"
            if yaml_path.exists():
                config = self.load_board_yaml(board_dir.name)
                if config:
                    boards[board_dir.name] = config

        return boards

