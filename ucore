def main():
    """Main entry point"""
    parser = argparse.ArgumentParser(
        description="MicroCore (ucore) - Unified Build & Flash CLI",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""
Examples:
  # Build & Flash
  %(prog)s build nucleo_f401re blink       # Build blink for Nucleo F401RE
  %(prog)s flash nucleo_f401re blink       # Build and flash blink
  %(prog)s clean nucleo_f401re             # Clean board build directory

  # List & Discover
  %(prog)s list boards                     # Show all supported boards
  %(prog)s list examples                   # Show all available examples

  # Board Configuration (YAML)
  %(prog)s new-board my_board              # Create new board with wizard
  %(prog)s validate-board nucleo_f401re    # Validate board YAML config
  %(prog)s generate-board nucleo_f401re    # Generate C++ from YAML
        """
    )

    subparsers = parser.add_subparsers(dest='command', help='Available commands')

    # List command
    list_parser = subparsers.add_parser('list', help='List boards or examples')
    list_parser.add_argument('type', nargs='?', choices=['boards', 'examples'],
                            default='boards', help='What to list (default: boards)')

    # Build command
    build_parser = subparsers.add_parser('build', help='Build example for board')
    build_parser.add_argument('board', help='Board name (e.g., nucleo_f401re)')
    build_parser.add_argument('example', help='Example name (e.g., blink)')
    build_parser.add_argument('--debug', action='store_true', help='Build debug version')

    # Flash command
    flash_parser = subparsers.add_parser('flash', help='Build and flash example to board')
    flash_parser.add_argument('board', help='Board name (e.g., nucleo_f401re)')
    flash_parser.add_argument('example', help='Example name (e.g., blink)')
    flash_parser.add_argument('--debug', action='store_true', help='Build debug version')
    flash_parser.add_argument('--reset', action='store_true', help='Force connect-under-reset mode')

    # Clean command
    clean_parser = subparsers.add_parser('clean', help='Clean build directory')
    clean_parser.add_argument('board', nargs='?', help='Board to clean (or all if omitted)')

    # Validate-board command
    validate_parser = subparsers.add_parser('validate-board', help='Validate board YAML configuration')
    validate_parser.add_argument('board', help='Board name to validate')

    # Generate-board command
    generate_parser = subparsers.add_parser('generate-board', help='Generate C++ config from YAML')
    generate_parser.add_argument('board', help='Board name to generate')

    # New-board command
    new_board_parser = subparsers.add_parser('new-board', help='Create new board configuration')
    new_board_parser.add_argument('board', help='Board name (e.g., my_custom_board)')

    args = parser.parse_args()

    if not args.command:
        parser.print_help()
        return 0

    builder = UCoreBuilder()

    try:
        if args.command == 'list':
            if args.type == 'boards':
                builder.list_boards()
            else:
                builder.list_examples()
            return 0

        elif args.command == 'build':
            build_type = "Debug" if args.debug else "Release"
            return builder.build(args.board, args.example, build_type)

        elif args.command == 'flash':
            build_type = "Debug" if args.debug else "Release"
            return builder.flash(args.board, args.example, build_type, args.reset)

        elif args.command == 'clean':
            builder.clean(args.board)
            return 0

        elif args.command == 'validate-board':
            return builder.validate_board(args.board)

        elif args.command == 'generate-board':
            return builder.generate_board(args.board)

        elif args.command == 'new-board':
            return builder.new_board(args.board)

        else:
            parser.print_help()
            return 1

    except KeyboardInterrupt:
        print_warning("\nOperation cancelled by user")
        return 130

    except Exception as e:
        print_error(f"Unexpected error: {e}")
        import traceback
        traceback.print_exc()
        return 1


if __name__ == "__main__":
    sys.exit(main())
