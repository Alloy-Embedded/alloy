        print("Press Enter to use default value shown in [brackets]")
        print()

        def prompt(question: str, default: str = "") -> str:
            if default:
                response = input(f"  {question} [{default}]: ").strip()
                return response if response else default
            else:
                while True:
                    response = input(f"  {question}: ").strip()
                    if response:
                        return response
                    print_warning("  This field is required!")

        # Collect information
        board_display_name = prompt("Board name", board_name.replace('_', ' ').title())
        vendor = prompt("Vendor (e.g., STMicroelectronics)")
        mcu_part = prompt("MCU part number (e.g., STM32F401RET6)")

