#!/usr/bin/env python3
"""
MicroCore (ucore) - Unified Build & Flash CLI

Simple, unified interface for building and flashing MicroCore examples.

Usage:
    ./ucore build <board> <example>         # Build example for board
    ./ucore flash <board> <example>         # Build and flash to board
    ./ucore smoke [--board <board>]         # Build smoke matrix via CLI
    ./ucore list [boards|examples]          # List available boards or examples
    ./ucore clean [board]                   # Clean build directory

Examples:
    ./ucore build nucleo_f401re blink       # Build blink for Nucleo F401RE
    ./ucore build nucleo_f401re rtos/simple_tasks
    ./ucore flash nucleo_f401re blink       # Build and flash blink
    ./ucore smoke --board nucleo_f401re     # Smoke-build supported combos
    ./ucore list boards                     # Show all supported boards
    ./ucore list examples                   # Show all available examples
    ./ucore clean nucleo_f401re             # Clean board build directory
"""

